@startuml Sales_Roleplay_Chatbot_Context

!theme plain
skinparam backgroundColor #FEFEFE
skinparam componentStyle uml2
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80

title System Context Diagram - Sales Roleplay Chatbot

rectangle "Sales Training System" as STS {
  component "Frontend\n(UI)" as UI
  component "Backend\n(Flask API)" as Backend
  component "SalesChatbot\nOrchestrator" as Chatbot
  component "SalesFlowEngine\n(FSM)" as FSM
  component "Signal Analysis" as Analysis
  component "Content Generation" as Content
  component "Session & Analytics" as Services
}

rectangle "AI Providers" as Providers {
  component "LLM\n(Groq, Sambanova)" as LLM
  component "Voice\n(STT/TTS)" as Voice
}

rectangle "External APIs" as External {
  component "Groq" as GroqAPI
  component "Sambanova" as SambanovaAPI
  component "Deepgram" as DeepgramAPI
  component "Edge TTS" as EdgeAPI
}

actor "Sales Rep" as User

User --> UI : Browser
UI --> Backend : REST API
Backend --> Chatbot : Orchestrate
Chatbot --> FSM : FSM Flow
Chatbot --> Analysis : Classify
Chatbot --> Content : Prompts
Chatbot --> LLM : LLM Provider
Chatbot --> Voice : Voice Ops
Chatbot --> Services : Persist/Log

LLM --> GroqAPI : API Call
LLM --> SambanovaAPI : API Call
Voice --> DeepgramAPI : API Call
Voice --> EdgeAPI : API Call

@enduml
