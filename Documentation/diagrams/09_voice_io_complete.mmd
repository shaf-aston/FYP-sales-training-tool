title: Voice Mode System — Complete Architecture (Single Comprehensive Diagram)
---
%%{init: {'flowchart': {'useHtmlLabels': true, 'curve': 'linear'}, 'theme': 'base'}}%%
graph TB
    NOTE["⚠ DIAGRAM LEGEND: Blue subgraphs=Client browser | Purple=Server backend<br/>Green=External services | Orange=Voice modes | Yellow=Unified flows | Gray=Tech mapping<br/>STT=Speech-to-Text | TTS=Text-to-Speech | M1/M2/M3=Three distinct voice mode paths"]

    subgraph BROWSER["🌐 BROWSER LAYER — Client-Side Voice Control"]
        subgraph VA["Input Management"]
            SR["Speech Recognition<br/>Web Speech API<br/>(speech.js)"]
            MR["Audio Capture<br/>MediaRecorder<br/>(voice.js)"]
        end

        subgraph VL["Voice Listening & Control"]
            STATE["Hand-Free Mode Toggle<br/>state: handsFreeMode<br/>__speechPausedForTTS flag"]
            STT_PAUSE["STT Pause Mechanism<br/>stopRecognition() before TTS<br/>startRecognition() after TTS"]
        end

        subgraph INT["Output Management"]
            NATIVE_TTS["Native Browser TTS<br/>speechSynthesis API<br/>(🔊 per-message)<br/>instant playback"]
            ORCH["app.js Orchestrator<br/>toggleMic() · toggleVoiceMode()<br/>playServerTTS() · interruptAssistant()"]
        end

        subgraph UI_OUT["User Interface"]
            UIR["Chat Render<br/>Messages · Input Bar<br/>Voice Buttons"]
        end

        SR -.-> VA
        MR -.-> VA
        VA --> VL
        VL -.-> INT
        NATIVE_TTS --> ORCH
        ORCH --> UIR
    end

    subgraph SERVER["⚙️ SERVER LAYER — Backend Voice Processing"]
        subgraph TEXT["Text Processing"]
            ROUTES["Flask voice.py Blueprint<br/>/api/voice/*"]
            CHATBOT["Chatbot Engine<br/>bot.chat() · generate_training()"]
        end

        subgraph VP["Voice Provider<br/>(voice_provider.py)"]
            VP_STT["Server STT Handler<br/>Deepgram Nova-2<br/>Rate Limited: 60s cooldown"]
            VP_TTS["Server TTS Handler<br/>Edge TTS Library<br/>Async Event Loop"]
            VOICES["Voice Config<br/>male_us · female_us<br/>male_uk · female_uk"]
        end

        ROUTES --> CHATBOT
        ROUTES --> VP
        VP_TTS --> VOICES
    end

    subgraph EXT["☁️ EXTERNAL SERVICES"]
        DG["Deepgram<br/>REST API<br/>Nova-2 Model<br/>transcription"]
        EDGE["Edge TTS<br/>Microsoft<br/>Neural Voices<br/>synthesis"]
    end

    subgraph MODES["📍 THREE VOICE MODES — Distinct Data Paths"]
        subgraph M1["Mode 1️⃣ — Per-Message TTS<br/>🔊 Button on Message"]
            M1_DESC["• Browser-only<br/>• speechSynthesis API<br/>• Zero server calls<br/>• Instant playback<br/>• Quality: OS-default"]
        end

        subgraph M2["Mode 2️⃣ — Manual Dictation<br/>🎤 Button in Input"]
            M2_DESC["• Browser Web Speech API<br/>• Text to input field<br/>• Manual or auto-send<br/>• No TTS synthesis<br/>• Works offline"]
        end

        subgraph M3["Mode 3️⃣ — Hands-Free Conversational<br/>🎯 Toggle Button"]
            M3_FLOW["Listen (STT) →<br/>Pause STT →<br/>Send to chat →<br/>Bot responds →<br/>Synthesize (Edge TTS) →<br/>Resume STT →<br/>Repeat"]
            M3_CRITICAL["⚠️ Critical: STT/TTS<br/>pause management prevents<br/>mic feedback loop"]
        end
    end



    subgraph TECH["🔧 TECHNOLOGY MAPPING — Service Layer"]
        subgraph STT_LAYER["Speech-to-Text Options"]
            STT1["Browser STT<br/>Web Speech API<br/>Used: M2, M3<br/>Latency: 100–500ms"]
            STT2["Server STT<br/>Deepgram Nova-2<br/>Used: /api/voice/chat<br/>Latency: 200–600ms"]
        end

        subgraph TTS_LAYER["Text-to-Speech Options"]
            TTS1["Browser TTS<br/>speechSynthesis<br/>Used: M1<br/>Latency: instant"]
            TTS2["Server TTS<br/>Edge TTS<br/>Used: M3, /api/voice/chat<br/>Latency: 800–2000ms"]
        end
    end

    subgraph INTEGRATION["↔️ INTEGRATION POINTS"]
        INT1["Browser ↔ Server:<br/>POST /api/chat<br/>(text message)"]
        INT2["Browser ↔ Server:<br/>POST /api/voice/synthesize<br/>(text + voice pref)"]
        INT3["Server ↔ Deepgram:<br/>REST API<br/>(audio transcription)"]
        INT4["Server ↔ Edge TTS:<br/>Async stream<br/>(text synthesis)"]
    end

    %% Connections from layers to modes
    BROWSER --> MODES
    SERVER --> MODES
    EXT --> MODES

    %% Connections to tech mapping
    MODES --> TECH

    %% Integration points
    TECH --> INTEGRATION

    %% External service connections
    VP_STT --> DG
    VP_TTS --> EDGE

    %% Data flow examples
    SR -->|spoken text| ORCH
    ORCH -->|synthesize request| ROUTES
    ROUTES -->|chat response| CHATBOT
    MR -->|audio blob| ROUTES

