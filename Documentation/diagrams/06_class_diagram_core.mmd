---
title: Core Class Diagram
---
%% ==========================================
%% PURPOSE: Illustrates the primary object-oriented structure of the Sales Chatbot core, including Enumerations for State/Strategy, Session storage models, and the Flow Engine.
%% ==========================================
%%{init: {"theme": "base"}}%%

classDiagram

    %% ── Enumerations ─────────────────────────────────────────────────────────
    class Strategy {
        <<enumeration>>
        INTENT
        CONSULTATIVE
        TRANSACTIONAL
    }

    class Stage {
        <<enumeration>>
        INTENT
        LOGICAL
        EMOTIONAL
        PITCH
        OBJECTION
    }

    %% ── DTOs ─────────────────────────────────────────────────────────────────
    class ChatResponse {
        <<dataclass>>
        +str content
        +float latency_ms
        +str provider
        +str model
        +int input_len
        +int output_len
    }

    class LLMResponse {
        <<dataclass>>
        +str content
        +str model
        +float latency_ms
        +Optional~str~ error
    }

    class ConversationState {
        <<dataclass>>
        +str intent
        +bool guarded
        +bool question_fatigue
        +bool decisive
        +__getitem__(str) Any
        +get(str, default) Any
    }

    %% ── Orchestrator ─────────────────────────────────────────────────────────
    class SalesChatbot {
        +BaseLLMProvider provider
        +str session_id
        +str product_type
        +str provider_type
        +SalesFlowEngine flow_engine
        -str _provider_name
        -str _model_name
        -str _ab_variant
        +chat(str) ChatResponse
        +generate_training(str, str) dict
        +answer_training_question(str) dict
        +rewind(int) dict
        +rewind_to_turn(int) bool
        +replay(list) None
        +save_session() None
        +load_session(str)$ SalesChatbot
        +get_conversation_summary() dict
        +record_session_end() None
        -_apply_advancement(str) None
        -_detect_and_switch_strategy(str) bool
        -_try_switch_to_provider(str) bool
        -_fallback(str, float, str) ChatResponse
    }
    note for SalesChatbot "chat() execution order: prompt → intent → LLM → fallback → persist → latency → FSM → objection → training."

    %% ── FSM ──────────────────────────────────────────────────────────────────
    class SalesFlowEngine {
        +Strategy flow_type
        +Strategy _initial_flow_type
        +dict flow_config
        +Stage current_stage
        +list~dict~ conversation_history
        +int stage_turn_count
        +str product_context
        +strategy_for_prompts Strategy
        +get_current_prompt(str) str
        +get_advance_target(str) Optional~Stage~
        +should_advance(str) bool
        +advance(Optional~Stage~) None
        +add_turn(str, str) None
        +switch_strategy(str) bool
        +reset_to_initial() None
        +restore_state(dict) None
        +get_summary() dict
        +to_dict() dict
    }
    note for SalesFlowEngine "strategy_for_prompts: INTENT → CONSULTATIVE templates."

    %% ── Provider Hierarchy ───────────────────────────────────────────────────
    class BaseLLMProvider {
        <<abstract>>
        +chat(...) LLMResponse*
        +is_available() bool*
        +get_model_name() str*
    }
    note for BaseLLMProvider "@auto_log_performance decorator wraps all concrete chat() implementations."

    class GroqProvider {
        -str model
        -groq.Groq client
        -threading.Lock _lock
        +chat(...) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for GroqProvider "Default: llama-3.3-70b-versatile."

    class OpenRouterProvider {
        -str model
        -requests.Session session
        -threading.Lock _lock
        -str api_key
        +chat(...) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for OpenRouterProvider "Default: llama-3.3-70b-instruct:free."

    class SambanovaProvider {
        -str model
        -openai.OpenAI client
        +chat(...) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for SambanovaProvider "Model: Meta-Llama-3.1-70B-Instruct."

    class DummyProvider {
        -str fixed_response
        +chat(...) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for DummyProvider "Always returns 'Test response'."

    class ProviderFactory {
        <<module>>
        +PROVIDERS dict$
        +create_provider(str, str)$ BaseLLMProvider
        +get_available_providers()$ dict
    }
    note for ProviderFactory "PROVIDERS = {'groq': GroqProvider, 'openrouter': OpenRouterProvider, 'sambanova': SambanovaProvider, 'dummy': DummyProvider}."

    %% ── Observability ────────────────────────────────────────────────────────
    class SessionAnalytics {
        <<service>>
        +record_session_start(...)$
        +record_stage_transition(...)$
        +record_intent_classification(str, str, int)$
        +record_objection_classified(...)$
        +record_strategy_switch(...)$
        +record_session_end(...)$
        +get_evaluation_summary()$ dict
    }
    note for SessionAnalytics "Writes to analytics.jsonl (project root)."

    class PerformanceTracker {
        <<service>>
        +MAX_METRICS_LINES int$
        +log_stage_latency(...)$
        +get_summary() dict$
        +get_provider_stats() dict$
    }
    note for PerformanceTracker "Writes to metrics.jsonl (project root) under threading.Lock."

    class QuickMatcher {
        -dict product_config
        +normalize(str) str
        +match_product(str) tuple
        -_match_product_normalized(str) tuple
        +match_signals(str, str) list
        +detect_preferences(str) dict
        +score_text_match(str, str, str) float
        +find_best_match(str, list, float) tuple
    }
    note for QuickMatcher "match_product() normalises then calls @lru_cache _match_product_normalized() — 'Cars' and 'cars' share cache."

    %% ── Relationships ────────────────────────────────────────────────────────
    SalesChatbot *-- SalesFlowEngine          : flow_engine (composition)
    SalesChatbot --> BaseLLMProvider          : uses provider
    SalesChatbot ..> ChatResponse             : returns
    SalesChatbot ..> SessionAnalytics         : records events
    SalesChatbot ..> PerformanceTracker       : logs latency

    SalesFlowEngine --> Strategy              : flow_type + _initial_flow_type
    SalesFlowEngine --> Stage                 : current_stage
    SalesFlowEngine ..> ConversationState     : reads via analysis.analyze_state()

    BaseLLMProvider <|-- GroqProvider
    BaseLLMProvider <|-- OpenRouterProvider
    BaseLLMProvider <|-- SambanovaProvider
    BaseLLMProvider <|-- DummyProvider
    BaseLLMProvider ..> LLMResponse           : returns

    ProviderFactory ..> GroqProvider          : instantiates
    ProviderFactory ..> OpenRouterProvider    : instantiates
    ProviderFactory ..> SambanovaProvider     : instantiates
    ProviderFactory ..> DummyProvider         : instantiates
    ProviderFactory ..> BaseLLMProvider       : returns as

