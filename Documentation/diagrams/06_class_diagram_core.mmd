%% DIAGRAM 6 — UML CLASS DIAGRAM: Core Classes
%% Replaces: old 03_class_diagram_core
%% Key change: verbose multi-paragraph notes trimmed to 1–2 essential facts per class.
%% Full algorithm detail is in 05_nlu_pipeline and 02_fsm_state_machine.

classDiagram

    %% ── Enumerations ─────────────────────────────────────────────────────────
    class Strategy {
        <<enumeration>>
        INTENT
        CONSULTATIVE
        TRANSACTIONAL
    }

    class Stage {
        <<enumeration>>
        INTENT
        LOGICAL
        EMOTIONAL
        PITCH
        OBJECTION
    }

    %% ── DTOs ─────────────────────────────────────────────────────────────────
    class ChatResponse {
        <<dataclass>>
        +str content
        +float latency_ms
        +str provider
        +str model
        +int input_len
        +int output_len
    }

    class LLMResponse {
        <<dataclass>>
        +str content
        +str model
        +float latency_ms
        +Optional~str~ error
    }

    class ConversationState {
        <<dataclass>>
        +str intent
        +bool guarded
        +bool question_fatigue
        +bool decisive
        +__getitem__(key str) Any
        +get(key str, default) Any
    }

    %% ── Orchestrator ─────────────────────────────────────────────────────────
    class SalesChatbot {
        +BaseLLMProvider provider
        +str session_id
        +str product_type
        +str provider_type
        +SalesFlowEngine flow_engine
        -str _provider_name
        -str _model_name
        -str _ab_variant
        +chat(user_message str) ChatResponse
        +generate_training(user_msg str, bot_reply str) dict
        +answer_training_question(question str) dict
        +rewind(steps int) dict
        +rewind_to_turn(turn_index int) bool
        +replay(history list) None
        +save_session() None
        +load_session(session_id str)$ SalesChatbot
        +get_conversation_summary() dict
        +record_session_end() None
        -_apply_advancement(user_message str) None
        -_detect_and_switch_strategy(user_message str) bool
        -_try_switch_to_provider(name str) bool
        -_fallback(message str, latency_ms float, user_message str) ChatResponse
    }
    note for SalesChatbot "chat() execution order: prompt → intent → LLM → fallback → persist → latency → FSM → objection → training\n_detect_and_switch_strategy(): INTENT mode only, runs post-LLM inside _apply_advancement()\nModule constants: _RECENT_HISTORY_WINDOW=-10 · _DEFAULT_TEMPERATURE=0.8 · _DEFAULT_MAX_TOKENS=200"

    %% ── FSM ──────────────────────────────────────────────────────────────────
    class SalesFlowEngine {
        +Strategy flow_type
        +Strategy _initial_flow_type
        +dict flow_config
        +Stage current_stage
        +list~dict~ conversation_history
        +int stage_turn_count
        +str product_context
        +strategy_for_prompts Strategy
        +get_current_prompt(user_message str) str
        +get_advance_target(user_message str) Optional~Stage~
        +should_advance(user_message str) bool
        +advance(target_stage Optional~Stage~) None
        +add_turn(user_msg str, bot_reply str) None
        +switch_strategy(new_strategy str) bool
        +reset_to_initial() None
        +restore_state(state dict) None
        +get_summary() dict
        +to_dict() dict
    }
    note for SalesFlowEngine "strategy_for_prompts: INTENT → CONSULTATIVE templates · else returns actual flow_type\nget_advance_target() 5 evaluation paths (see 02_fsm_state_machine for full detail)\nADVANCEMENT_RULES dict (module-level): maps rule name strings → rule functions"

    %% ── Provider Hierarchy ───────────────────────────────────────────────────
    class BaseLLMProvider {
        <<abstract>>
        +chat(messages list, temperature float, max_tokens int, stage str) LLMResponse*
        +is_available() bool*
        +get_model_name() str*
    }
    note for BaseLLMProvider "@auto_log_performance decorator wraps all concrete chat() implementations"

    class GroqProvider {
        -str model
        -groq.Groq client
        -threading.Lock _lock
        +chat(messages list, temperature float, max_tokens int, stage str) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for GroqProvider "Default: llama-3.3-70b-versatile · Env: SAFE_GROQ_API_KEY or GROQ_API_KEY · ~980 ms avg"

    class OpenRouterProvider {
        -str model
        -requests.Session session
        -threading.Lock _lock
        -str api_key
        +chat(messages list, temperature float, max_tokens int, stage str) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for OpenRouterProvider "Default: llama-3.3-70b-instruct:free · Env: OPENROUTER_API_KEY · ~1200 ms · Fallback 1"

    class SambanovaProvider {
        -str model
        -openai.OpenAI client
        +chat(messages list, temperature float, max_tokens int, stage str) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for SambanovaProvider "Model: Meta-Llama-3.1-70B-Instruct · Env: SAMBANOVA_API_KEY · openai SDK compat\nFile exists but NOT registered in factory.py — not used in any active code path"

    class DummyProvider {
        -str fixed_response
        +chat(messages list, temperature float, max_tokens int, stage str) LLMResponse
        +is_available() bool
        +get_model_name() str
    }
    note for DummyProvider "Always returns 'Test response' · model='dummy' · latency_ms=0 · test suite use only"

    class ProviderFactory {
        <<module>>
        +PROVIDERS dict$
        +create_provider(provider_type str, model str)$ BaseLLMProvider
        +get_available_providers()$ dict
    }
    note for ProviderFactory "PROVIDERS = {'groq': GroqProvider, 'openrouter': OpenRouterProvider, 'sambanova': SambanovaProvider, 'dummy': DummyProvider}"

    %% ── Observability ────────────────────────────────────────────────────────
    class SessionAnalytics {
        <<service>>
        +record_session_start(session_id str, product_type str, strategy str, ab_variant str)$
        +record_stage_transition(session_id str, from_stage str, to_stage str, strategy str, user_turns_in_stage int)$
        +record_intent_classification(session_id str, intent_level str, user_turn_count int)$
        +record_objection_classified(session_id str, objection_type str, strategy str, user_turn_count int)$
        +record_strategy_switch(session_id str, from_strategy str, to_strategy str, reason str, user_turn_count int)$
        +record_session_end(session_id str, final_stage str, final_strategy str, turns int)$
        +get_evaluation_summary()$ dict
    }
    note for SessionAnalytics "Writes to analytics.jsonl (project root) · rotation: 10 000 → keep 5 000 lines\nget_evaluation_summary() reads full file → stage reach rates · intent distribution · A/B variant split"

    class PerformanceTracker {
        <<service>>
        +MAX_METRICS_LINES int$
        +log_stage_latency(session_id str, stage str, strategy str, latency_ms float, provider str, model str, user_message_length int, bot_response_length int)$
        +get_summary() dict$
        +get_provider_stats() dict$
    }
    note for PerformanceTracker "Writes to metrics.jsonl (project root) under threading.Lock · MAX_METRICS_LINES=5000 → trim to 2500\nget_provider_stats() feeds GET /api/health response"

    class QuickMatcher {
        -dict product_config
        +normalize(text str) str
        +match_product(text str) tuple
        -_match_product_normalized(text str) tuple
        +match_signals(text str, category str) list
        +detect_preferences(text str) dict
        +score_text_match(text str, target str, method str) float
        +find_best_match(text str, candidates list, threshold float) tuple
    }
    note for QuickMatcher "match_product() normalises then calls @lru_cache _match_product_normalized() — 'Cars' and 'cars' share cache\nConfidence tiers: exact=1.0 · alias=0.95 · fuzzy+context=0.6–0.8 · threshold ≥0.7 accepted"

    %% ── Relationships ────────────────────────────────────────────────────────
    SalesChatbot *-- SalesFlowEngine          : flow_engine (composition)
    SalesChatbot --> BaseLLMProvider          : uses provider
    SalesChatbot ..> ChatResponse             : returns
    SalesChatbot ..> SessionAnalytics         : records events
    SalesChatbot ..> PerformanceTracker       : logs latency

    SalesFlowEngine --> Strategy              : flow_type + _initial_flow_type
    SalesFlowEngine --> Stage                 : current_stage
    SalesFlowEngine ..> ConversationState     : reads via analysis.analyze_state()

    BaseLLMProvider <|-- GroqProvider
    BaseLLMProvider <|-- OpenRouterProvider
    BaseLLMProvider <|-- SambanovaProvider
    BaseLLMProvider <|-- DummyProvider
    BaseLLMProvider ..> LLMResponse           : returns

    ProviderFactory ..> GroqProvider          : instantiates
    ProviderFactory ..> OpenRouterProvider    : instantiates
    ProviderFactory ..> SambanovaProvider     : instantiates
    ProviderFactory ..> DummyProvider         : instantiates
    ProviderFactory ..> BaseLLMProvider       : returns as
