flowchart LR

    classDef in fill:#66BB6A,stroke:#1B5E20,stroke-width:2px,color:#fff
    classDef step fill:#42A5F5,stroke:#0D47A1,stroke-width:2px,color:#fff
    classDef decide fill:#F57F17,stroke:#E65100,stroke-width:2px,color:#fff
    classDef out fill:#388E3C,stroke:#1B5E20,stroke-width:2px,color:#fff
    classDef hub fill:#26C6DA,stroke:#006064,stroke-width:2px,color:#fff
    classDef data fill:#78909C,stroke:#37474F,stroke-width:2px,color:#fff
    classDef provider fill:#AB47BC,stroke:#4A148C,stroke-width:2px,color:#fff

    %% ---------------- INPUT ----------------
    INPUT[User message + history]:::in --> CONTROLLER[ChatController<br/>/chat route]:::step

    %% ---------------- CORE PIPELINE ----------------
    CONTROLLER --> CHAT_SERVICE[ChatService.handle_message()]:::step

    CHAT_SERVICE --> ANALYZE[AnalysisEngine<br/>intent + state detection]:::step
    ANALYZE --> STATE[ConversationState]:::data

    STATE --> FSM_DECIDE[SalesFlowEngine<br/>decide_next_action()]:::step

    FSM_DECIDE --> CHECK_OVERRIDE{Override rule?}:::decide

    CHECK_OVERRIDE -- Yes --> OVERRIDE_PROMPT[Override Prompt Builder]:::step
    CHECK_OVERRIDE -- No --> BUILD_PROMPT[PromptBuilder<br/>stage + tactics + context]:::step

    OVERRIDE_PROMPT --> FINAL_PROMPT[Final Prompt]:::step
    BUILD_PROMPT --> FINAL_PROMPT

    %% ---------------- LLM ----------------
    FINAL_PROMPT --> BUILD_MESSAGES[MessageBuilder<br/>system + history + user]:::step

    BUILD_MESSAGES --> PROVIDER_ROUTER[ProviderRouter]:::provider
    PROVIDER_ROUTER --> PROVIDER_HUB["LLM Providers"]:::hub

    PROVIDER_HUB --> GROQ[GroqProvider]:::provider
    PROVIDER_HUB --> SAMBANOVA[SambaNovaProvider]:::provider

    GROQ --> LLM_RESPONSE[LLM Response]:::out
    SAMBANOVA --> LLM_RESPONSE

    %% ---------------- POST PROCESS ----------------
    LLM_RESPONSE --> UPDATE_STATE[SalesFlowEngine<br/>update_state()]:::step
    UPDATE_STATE --> SAVE_SESSION[SessionService.save()]:::step
    SAVE_SESSION --> LOGGING[PerformanceTracker + Analytics]:::step

    LOGGING --> RESPONSE[JSON Response to UI]:::out

    %% ---------------- CONFIG ----------------
    subgraph CONFIGS
        CONFIG_HUB["Config Loader"]:::hub
        PRODUCT[product.yaml]:::data
        TACTICS[tactics.yaml]:::data
        OVERRIDES[overrides.yaml]:::data
        FLOWS[flow_definitions.yaml]:::data

        CONFIG_HUB --> PRODUCT
        CONFIG_HUB --> TACTICS
        CONFIG_HUB --> OVERRIDES
        CONFIG_HUB --> FLOWS
    end

    CONFIG_HUB --> BUILD_PROMPT
    CONFIG_HUB --> FSM_DECIDE