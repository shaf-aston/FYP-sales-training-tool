    style WEB_LAYER fill:#E3F2FD,stroke:#0D47A1,stroke-width:2px,color:#000
    style PROVIDERS fill:#F3E5F5,stroke:#4A148C,stroke-width:2px,color:#000
    style DATA fill:#ECEFF1,stroke:#37474F,stroke-width:1px,color:#000

    style CHATBOT_ENGINE fill:#FFFACD,stroke:#DAA520,stroke-width:1px
    style DECISION_LOGIC fill:#FFE4B5,stroke:#FF8C00,stroke-width:1px
    style PROMPT_ASSEMBLY fill:#FFDAB9,stroke:#FF6347,stroke-width:1px
    style KNOWLEDGE_SYS fill:#E6F9E6,stroke:#228B22,stroke-width:1px
    style TRAINING_EVAL fill:#FFE4E1,stroke:#DC143C,stroke-width:1px

    style PROSPECT_ENGINE fill:#F5E6FF,stroke:#9932CC,stroke-width:1px
    style PROSPECT_BEHAVIOR fill:#F5E6FF,stroke:#9932CC,stroke-width:1px
    style PROSPECT_EVAL fill:#FFD1DC,stroke:#C71585,stroke-width:1px

    style WEB_ROUTES fill:#E8F4FF,stroke:#4A90E2,stroke-width:1px
    style SESSION_MANAGERS fill:#C5E1FF,stroke:#1E40AF,stroke-width:1px

    style CONFIG fill:#F0F4F8,stroke:#455A64,stroke-width:1px
    style STORAGE fill:#E0E7FF,stroke:#3F51B5,stroke-width:1px

