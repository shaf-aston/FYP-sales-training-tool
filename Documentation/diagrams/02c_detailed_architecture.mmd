title: Chatbot Detailed Architecture (Enhanced)
---
%% Caption: Detailed architecture map showing web layer, chatbot core, prospect mode, providers, and data. Plain-language notes added for non-technical readers; no emojis used
%%{init: {'flowchart': {'useHtmlLabels': true}}}%%
flowchart TD
    %% ===== CSS STYLING =====
    classDef client fill:#66BB6A,stroke:#1B5E20,stroke-width:2px,color:#fff,font-weight:bold
    classDef ui fill:#81C784,stroke:#2E7D32,stroke-width:2px,color:#fff
    classDef web fill:#42A5F5,stroke:#0D47A1,stroke-width:2px,color:#fff
    classDef session_mgr fill:#29B6F6,stroke:#01579B,stroke-width:2px,color:#fff,font-size:11px
    classDef core fill:#FFA726,stroke:#E65100,stroke-width:2px,color:#fff
    classDef fsm fill:#FFB74D,stroke:#EF6C00,stroke-width:2px,color:#fff
    classDef analysis fill:#FFCC80,stroke:#F57F17,stroke-width:2px,color:#333
    classDef provider fill:#AB47BC,stroke:#4A148C,stroke-width:2px,color:#fff
    classDef data_config fill:#78909C,stroke:#37474F,stroke-width:2px,color:#fff
    classDef persistence fill:#64B5F6,stroke:#1565C0,stroke-width:2px,color:#fff
    classDef evaluator fill:#EC407A,stroke:#880E4F,stroke-width:2px,color:#fff
    classDef knowledge fill:#AED581,stroke:#558B2F,stroke-width:2px,color:#fff
    classDef util fill:#B0BEC5,stroke:#455A64,stroke-width:2px,color:#fff
    classDef hub fill:#26C6DA,stroke:#006064,stroke-width:2px,color:#fff,font-weight:bold


    LEGEND["DIAGRAM LEGEND: Green=client/UI | Blue=web/API | Orange=core logic<br/>Light orange=FSM/decisions | Purple=LLM providers | Pink=prospect/training<br/>Gray=config/storage | Teal=topic hubs (orchestration containers)<br/>Solid arrow=direct call | Dashed=optional/reference"]:::knowledge


    %% ===== INPUT LAYER =====
    U[User]:::client
    UI_WEB[Browser\nindex.html\nchat.html\nprospect.html]:::ui
    UI_VOICE[Voice Input\nTTS Output]:::ui

    %% ===== WEB LAYER =====
    subgraph WEB_LAYER["<div style='text-align:left; padding-left:6px;'>WEB LAYER</div>"]
        direction TB
        WEB_HUB(["Web Gateway"]):::hub

        subgraph WEB_ROUTES["<div style='text-align:left; padding-left:6px;'>API Routes</div>"]
            APP["app.py\nBlueprint / Auth"]:::web
            SESSION_ROUTE["routes/session.py\nInit / Resume / Reset"]:::web
            CHAT_ROUTE["routes/chat.py\nPOST /api/chat"]:::web
            PROSPECT_ROUTE["routes/prospect.py\nProspect mode endpoints"]:::web
            ANALYTICS_ROUTE["routes/analytics.py\nQuiz / Training / Reports"]:::web
            VOICE_ROUTE["routes/voice.py\nAudio I/O"]:::web
        end

        subgraph SESSION_MANAGERS["<div style='text-align:left; padding-left:6px;'>Session Managers</div>"]
            SESS_MGR["SessionSecurityManager\n(Main chatbot mode)"]:::session_mgr
            PROSPECT_SESS_MGR["ProspectSessionManager\n(Buyer training mode)"]:::session_mgr
            VALIDATOR["InputValidator\nMessage length/content"]:::session_mgr
        end

        WEB_HUB --> WEB_ROUTES
        WEB_HUB --> SESSION_MANAGERS
    end

    %% ===== SESSION LIFECYCLE (init / resume / recovery) =====
    subgraph SESSION_LIFECYCLE["<div style='text-align:left; padding-left:6px;'>Session lifecycle: init, resume, persist, recover</div>"]
        direction TB
        CLIENT_BOOT[web/static/app.js: load local sessionId/history]:::ui --> API_INIT[POST /api/init -> routes/session.py]:::web
        API_INIT --> HAS_ID{session_id provided?}:::data_config
        HAS_ID -- No --> NEW_SESSION[chatbot.py: create new SalesChatbot instance]:::core
        HAS_ID -- Yes --> CHECK_MEM[SessionSecurityManager.get(session_id)]:::session_mgr
        CHECK_MEM -- Yes --> RETURN_LIVE[Return live session + history]:::persistence
        CHECK_MEM -- No --> LOAD_DISK[session_persistence.py: load_session()]:::persistence
        LOAD_DISK -- Yes --> REHYDRATE[rehydrate into session manager]:::core
        LOAD_DISK -- No --> NEW_SESSION
        REHYDRATE --> SESSION_READY[Active session in memory]:::session_mgr
        NEW_SESSION --> SESSION_READY
    end

    %% ===== CHATBOT CORE LAYER (Seller Mode) =====
    subgraph CHATBOT_CORE["<div style='text-align:left; padding-left:6px;'>CHATBOT CORE (Seller Training)</div>"]
        direction TB
        CORE_HUB(["Orchestrator"]):::hub

        subgraph CHATBOT_ENGINE["<div style='text-align:left; padding-left:6px;'>Chatbot Session</div>"]
            BOT["chatbot.py\nSalesChatbot.chat()"]:::core
            HISTORY["conversation_history\n+ strategy state"]:::util
        end

        subgraph DECISION_LOGIC["<div style='text-align:left; padding-left:6px;'>Decision & Analysis</div>"]
            FSM["flow.py\nFSM: stage\n+ strategy + advance"]:::fsm
            ANALYSIS["analysis.py\nintent / guarded\n/ objection / pref"]:::analysis
            OVERRIDE["overrides.py\nstage-based\nconditions"]:::analysis
        end

        subgraph PROMPT_ASSEMBLY["<div style='text-align:left; padding-left:6px;'>Prompt Assembly</div>"]
            CONTENT["content.py\ngenerate_stage_prompt()\n+ acknowledgment\n+ tactic guidance"]:::core
            PROMPTS["prompts.py\nSHARED_RULES\n+ STRATEGY_PROMPTS"]:::core
        end

        subgraph KNOWLEDGE_SYS["<div style='text-align:left; padding-left:6px;'>Knowledge & Context</div>"]
            KNOWLEDGE["knowledge.py\ncustom product\nknowledge loader"]:::knowledge
            LOADER["loader.py\nYAML → cache\n+ product matching"]:::util
        end

        subgraph TRAINING_EVAL["<div style='text-align:left; padding-left:6px;'>Training & Evaluation</div>"]
            TRAINER["chatbot/trainer.py\ngenerate coaching\nfeedback"]:::evaluator
            QUIZ["chatbot/quiz.py\nstage ID / next-move\n/ direction quizzes"]:::evaluator
            ANALYTICS_CORE["session_analytics.py\nstage transitions\nintent distribution"]:::persistence
        end

        CORE_HUB --> CHATBOT_ENGINE
        CHATBOT_ENGINE --> DECISION_LOGIC
        DECISION_LOGIC --> PROMPT_ASSEMBLY
        PROMPT_ASSEMBLY --> KNOWLEDGE_SYS
        CHATBOT_ENGINE --> TRAINING_EVAL
    end

    %% ===== PROSPECT MODE LAYER (Buyer Training) =====
    subgraph PROSPECT_CORE["<div style='text-align:left; padding-left:6px;'>PROSPECT MODE (Buyer Training)</div>"]
        direction TB
        PROSPECT_HUB(["Role-Reversal Trainer"]):::hub

        subgraph PROSPECT_ENGINE["<div style='text-align:left; padding-left:6px;'>Prospect Session</div>"]
            PROSPECT["prospect.py\nProspectSession\n(bot = buyer)"]:::core
            PERSONA["select_persona()\nP_STATE:\nreadiness,\nneeds, objections"]:::analysis
            PROSPECT_HIST["conversation_history"]:::util
        end

        subgraph PROSPECT_BEHAVIOR["<div style='text-align:left; padding-left:6px;'>Buyer Personality Engine</div>"]
            DIFFICULTY["difficulty_profiles\n(easy/medium/hard)"]:::data_config
            BEHAVIOR["behavior_rules\n+ readiness model\n+ objection triggers"]:::analysis
        end

        subgraph PROSPECT_EVAL["<div style='text-align:left; padding-left:6px;'>Prospect Evaluation</div>"]
            EVALUATOR["prospect_evaluator.py\nreadiness_score()\ncommitment_detection()"]:::evaluator
            PROSPECT_ANALYTICS["prospect state:\nhas_committed\nhas_walked"]:::persistence
        end

        PROSPECT_HUB --> PROSPECT_ENGINE
        PROSPECT_ENGINE --> PROSPECT_BEHAVIOR
        PROSPECT_ENGINE --> PROSPECT_EVAL
    end

    %% ===== LLM PROVIDER LAYER =====
    subgraph PROVIDERS["<div style='text-align:left; padding-left:6px;'>LLM PROVIDERS</div>"]
        direction TB
        PROV_HUB(["LLM Factory"]):::hub

        FACTORY["providers/factory.py\ncreate_provider()"]:::provider
        GROQ["groq_provider.py\nPrimary (fast)"]:::provider
        SAMBA["sambanova_provider.py\nFallback"]:::provider
        BASE["base_llm_provider.py\nInterface"]:::provider

        FACTORY --> BASE
        BASE --> GROQ
        BASE --> SAMBA
    end

    %% ===== DATA & PERSISTENCE LAYER =====
    subgraph DATA["<div style='text-align:left; padding-left:6px;'>CONFIG & PERSISTENCE</div>"]
        direction TB
        DATA_HUB(["Data\nGateway"]):::hub

        subgraph CONFIG["<div style='text-align:left; padding-left:6px;'>Configuration</div>"]
            SIGNALS["signals.yaml\nintent / objections\nguardedness / commitment"]:::data_config
            ANALYSIS_CFG["analysis_config.yaml\nthresholds / patterns"]:::data_config
            PRODUCT_CFG["product_config.yaml\nproduct data + aliases"]:::data_config
            PROSPECT_CFG["prospect_config.yaml\ndifficulty profiles\npersonas"]:::data_config
            TACTICS_CFG["tactics.yaml\nelicitation / acknowledgment"]:::data_config
            OBJECTION_FLOWS["objection_flows.yaml\nSOP per type"]:::data_config
            OVERRIDES_CFG["overrides.yaml\nstage-based templates"]:::data_config
        end

        subgraph STORAGE["Session & Metrics Storage"]
            SESS_PERSIST["session_persistence.py\nserialize/deserialize"]:::persistence
            JSONL_STORE["jsonl_store.py\nmetrics.jsonl\nanalytics.jsonl"]:::persistence
            PERF_TRACK["performance.py\nlatency + provider\nmetrics"]:::persistence
            SESS_DIR["sessions/*.json\n(filesystem store)"]:::persistence
        end

        DATA_HUB --> CONFIG
        DATA_HUB --> STORAGE
    end

    %% ===== CONNECTION ARROWS =====

    %% ===== TURN PROCESSING (per chat turn) =====
    subgraph TURN_PROCESSING["<div style='text-align:left; padding-left:6px;'>TURN PROCESSING (per chat turn)</div>"]
        direction TB
        REQ[POST /api/chat {session_id, user_message}]:::web
        ROUTE[routes/chat.py -> chatbot.py:SalesChatbot.chat()]:::web
        ANALYSE[analysis.py: analyse_state() / classify_objection()]:::analysis
        PROMPT_GEN[content.py: generate_stage_prompt() / prompts.py SHARED_RULES]:::core
        PROVIDER_SELECT[providers/factory.py: create_provider()]:::provider
        LLM_CALL[LLM Provider (groq / sambanova) -> provider.chat()]:::provider
        ADD_TURN[flow.py: add_turn(user, bot_reply)]:::fsm
        SAVE_SESSION[chatbot.py: save_session() — write sessions/<id>.json]:::persistence
        PERF_LOG[analytics/performance.py: log_stage_latency()]:::persistence
        APPLY_ADV[flow.py: _apply_advancement() — synchronous advancement]:::fsm
        RESP[JSON response -> client]:::web

        %% Exact execution order per codebase
        REQ --> ROUTE --> ANALYSE --> PROMPT_GEN --> PROVIDER_SELECT --> LLM_CALL --> ADD_TURN --> SAVE_SESSION --> PERF_LOG --> APPLY_ADV --> RESP

        %% optional/conditional paths
        %% Optional coaching/training is invoked by the web route after `chat()` returns
        RESP -. optional .-> POST_TRAINING[routes/chat.py -> bot.generate_training()]:::evaluator
        POST_TRAINING -.-> RESP

        %% reuse existing hubs to avoid duplication
        PROMPT_GEN -.-> CONFIG_HUB
        PROVIDER_SELECT -.-> PROV_HUB
        SAVE_SESSION -.-> DATA_HUB
    end

    %% User input flows
    U --> UI_WEB
    U --> UI_VOICE

    %% UI to Web Layer
    UI_WEB --> WEB_HUB
    UI_VOICE --> VOICE_ROUTE

    %% Bundle web routes into the Web Gateway hub to reduce arrow clutter
    WEB_HUB --> APP & SESSION_ROUTE & CHAT_ROUTE & PROSPECT_ROUTE & ANALYTICS_ROUTE & VOICE_ROUTE

    %% Route incoming web requests to the chatbot core and prospect hubs
    WEB_HUB --> CORE_HUB
    PROSPECT_ROUTE --> PROSPECT_HUB

    %% Chatbot Core to Providers
    CORE_HUB --> PROV_HUB

    %% Prospect Core to Providers
    PROSPECT_HUB --> PROV_HUB

    %% All systems access Data/Config
    CORE_HUB ---> DATA_HUB
    PROSPECT_HUB ---> DATA_HUB
    WEB_HUB ---> DATA_HUB
    PROV_HUB ---> DATA_HUB

    %% Training/Quiz use evaluation components
    TRAINING_EVAL -.->|generate feedback| ANALYTICS_ROUTE

    %% Prospect evaluation uses session state
    PROSPECT_EVAL -.->|update state| ANALYTICS_ROUTE
    
    %% ===== STYLING =====
