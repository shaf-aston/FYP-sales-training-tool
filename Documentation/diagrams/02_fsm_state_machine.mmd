---
title: FSM State Machine (All Strategies)
---
%%{init: {"theme": "base"}}%%

stateDiagram-v2

    classDef initClass      fill:#78909C,stroke:#37474F,color:#fff
    classDef intentClass    fill:#42A5F5,stroke:#0D47A1,color:#fff
    classDef consultClass   fill:#FFA726,stroke:#E65100,color:#fff
    classDef transClass     fill:#AB47BC,stroke:#4A148C,color:#fff
    classDef stageIntent    fill:#42A5F5,stroke:#0D47A1,color:#fff
    classDef stageLogical   fill:#26C6DA,stroke:#006064,color:#fff
    classDef stageEmotional fill:#AB47BC,stroke:#4A148C,color:#fff
    classDef stagePitch     fill:#FFA726,stroke:#E65100,color:#fff
    classDef stageObj       fill:#EC407A,stroke:#880E4F,color:#fff
    classDef terminalClass  fill:#388E3C,stroke:#1B5E20,color:#fff

    [*] --> StrategyInit : POST /api/init

    state StrategyInit {
        [*] --> LoadConfig
        LoadConfig --> SetStrategy
        note right of LoadConfig
            get_product_settings(product_type)
            default: strategy = "intent"
            SalesFlowEngine(flow_type=strategy)
        end note
        SetStrategy --> [*] : flow_type resolved
    }

    StrategyInit --> IntentDiscovery : flow_type == "intent"
    StrategyInit --> Consultative    : flow_type == "consultative"
    StrategyInit --> Transactional   : flow_type == "transactional"

    state "INTENT — Discovery Mode" as IntentDiscovery {
        [*] --> ID_INTENT
        state "Stage.INTENT — bot probes for need, problem, context" as ID_INTENT

        ID_INTENT --> ID_INTENT         : no signals, turns < 3
        ID_INTENT --> ToConsultative    : consultative signals detected
        ID_INTENT --> ToTransactional   : transactional signals detected
        ID_INTENT --> ToConsultativeDef : turns >= 3 with no signals (default)

        ToConsultative    --> [*]
        ToTransactional   --> [*]
        ToConsultativeDef --> [*]

        note right of ID_INTENT
            _detect_and_switch_strategy() in chatbot.py
            All paths call record_strategy_switch()
        end note
    }

    IntentDiscovery --> Consultative  : switched to CONSULTATIVE
    IntentDiscovery --> Transactional : switched to TRANSACTIONAL

    state "CONSULTATIVE — 5 stages (NEPQ / Impact Formula)" as Consultative {
        [*] --> C_INTENT

        state "Stage.INTENT — Get tangible need + experience" as C_INTENT
        state "Stage.LOGICAL — Two-phase probe: cause + like/dislike (min 2 turns)" as C_LOGICAL
        state "Stage.EMOTIONAL — Identity Frame + Future Pacing + COI (min 3 turns)" as C_EMOTIONAL
        state "Stage.PITCH — 3-pillar + assumptive close" as C_PITCH
        state "Stage.OBJECTION — Classify + Reframe (7 types)" as C_OBJECTION
        state "SOLD" as SOLD_C
        state "WALKED" as WALKED_C

        C_INTENT    --> C_LOGICAL   : user_has_clear_intent()
        C_LOGICAL   --> C_EMOTIONAL : user_shows_doubt()
        C_EMOTIONAL --> C_PITCH     : user_expressed_stakes()
        C_PITCH     --> C_OBJECTION : commitment_or_objection()
        C_OBJECTION --> SOLD_C      : committed
        C_OBJECTION --> WALKED_C    : walkaway

        C_LOGICAL   --> C_PITCH : commitment signal OR demands_directness
        C_EMOTIONAL --> C_PITCH : commitment signal OR demands_directness

        C_INTENT    --> C_INTENT    : still discovering
        C_LOGICAL   --> C_LOGICAL   : probing — no signal yet
        C_EMOTIONAL --> C_EMOTIONAL : eliciting — no signal yet
        C_OBJECTION --> C_OBJECTION : reframe cycle

        SOLD_C   --> [*]
        WALKED_C --> [*]
    }

    state "TRANSACTIONAL — 3 stages (NEEDS → MATCH → CLOSE)" as Transactional {
        [*] --> T_INTENT

        state "Stage.INTENT — Gather budget + use-case (max 2 turns)" as T_INTENT
        state "Stage.PITCH — Present matching options, assumptive close" as T_PITCH
        state "Stage.OBJECTION — Classify + Reframe (same 7 types)" as T_OBJECTION
        state "SOLD" as SOLD_T
        state "WALKED" as WALKED_T

        T_INTENT    --> T_PITCH     : user_has_clear_intent() OR demands_directness
        T_PITCH     --> T_OBJECTION : commitment_or_objection()
        T_OBJECTION --> SOLD_T      : committed
        T_OBJECTION --> WALKED_T    : walkaway

        T_INTENT    --> T_INTENT    : still gathering
        T_OBJECTION --> T_OBJECTION : reframe cycle

        SOLD_T   --> [*]
        WALKED_T --> [*]
    }

    class StrategyInit      initClass
    class IntentDiscovery   intentClass
    class Consultative      consultClass
    class Transactional     transClass
    class ID_INTENT         stageIntent
    class C_INTENT          stageIntent
    class C_LOGICAL         stageLogical
    class C_EMOTIONAL       stageEmotional
    class C_PITCH           stagePitch
    class C_OBJECTION       stageObj
    class T_INTENT          stageIntent
    class T_PITCH           stagePitch
    class T_OBJECTION       stageObj
    class LoadConfig        initClass
    class SetStrategy       initClass
    class ToConsultative    consultClass
    class ToTransactional   transClass
    class ToConsultativeDef consultClass
    class SOLD_C            terminalClass
    class SOLD_T            terminalClass
    class WALKED_C          stageObj
    class WALKED_T          stageObj
