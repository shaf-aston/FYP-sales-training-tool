%%{init: {"theme": "base", "flowchart": {"nodeSpacing": 40, "rankSpacing": 40}}}%%

graph TD
    classDef junctionStyle stroke-width:0px,fill:transparent,font-size:1px

Browser(["🌐 Browser — HTML5 SPA"]):::client


subgraph Flask["⚙️  Flask 3.0  ·  Python 3.10+  ·  localhost:5000 / Render cloud"]
    direction TB

    subgraph Web["Web Layer  (src/web/)"]
        direction LR
        App["app.py<br/>(REST API Gateway)"]:::web
        Sec["SecurityManager<br/>(Rate Limit & Validation)"]:::web
    end

    subgraph Core["Chatbot Core  (src/chatbot/)"]
        direction TB
        Bot["SalesChatbot<br/>(Session Orchestrator)"]:::core
        FSM["SalesFlowEngine<br/>(FSM State Manager)"]:::core
        NLU["AnalysisEngine<br/>(NLU & Signal Detection)"]:::core
        Content["PromptEngine<br/>(4-Tier Prompt Assembly)"]:::core
        Loader["ConfigLoader<br/>(YAML Cache & Matching)"]:::core
    end

    subgraph Features["Feature Modules  (src/chatbot/)"]
        direction LR
        Trainer["SalesTrainer<br/>(Feedback Generation)"]:::feature
        Quiz["QuizEngine<br/>(Assessment)"]:::feature
        Prospect["ProspectSession<br/>(AI Buyer Role-Play)"]:::feature
        WebSearch["web_search.py<br/>WebSearchService: duckduckgo_search<br/>TTL cache for objection handling context"]:::feature
        Know["knowledge.py<br/>CRUD for custom product info via /api/knowledge<br/>ALLOWED_FIELDS whitelist · MAX_FIELD_LENGTH cap per field<br/>get_custom_knowledge_text() injected into product_context<br/>at SalesChatbot.__init__ as '--- BEGIN CUSTOM PRODUCT DATA ---'"]:::feature
    end

    subgraph Providers["LLM Provider Layer  (src/chatbot/providers/)"]
        direction LR
        Factory["ProviderFactory<br/>(Registry Pattern)"]:::prov
        ProvBase["BaseLLMProvider (ABC)<br/>(LLM Interface)"]:::prov
        VoiceProv["VoiceProvider (voice_provider.py)<br/>STT: Deepgram → fallback Groq Whisper<br/>TTS: edge-tts (async event loop in background thread)"]:::prov
    end

    subgraph Obs["Observability  (src/chatbot/)"]
        direction LR
        Ana["SessionAnalytics<br/>(Event Logging)"]:::obs
        Perf["PerformanceTracker<br/>(Latency Metrics)"]:::obs
    end
end

subgraph LLMs["☁️  External LLM APIs — 3-tier fallback chain (Groq free tier rate-limits)"]
    direction LR
    G["🟢 Groq Cloud — Primary<br/>api.groq.com/openai/v1<br/>llama-3.3-70b-versatile<br/>groq-sdk · Avg ~980 ms"]:::llm
    SN["🟠 SambaNova — Fallback 1<br/>api.sambanova.ai/v1<br/>Meta-Llama-3.1-70B-Instruct<br/>Registered · openai SDK compat"]:::llm
    OR["🟡 OpenRouter — Fallback 1<br/>openrouter.ai/api/v1<br/>llama-3.3-70b-instruct:free<br/>requests.Session · ~1200 ms"]:::llm
end

subgraph FS["💾  File System — Runtime Persistence"]
    direction LR
    F_S["sessions/{id}.json<br/>(Session State Snapshots)"]:::fs
    F_J["analytics.jsonl · metrics.jsonl<br/>(Event Logs)"]:::fs
    F_Y["src/config/ (9 YAML files)<br/>(Configuration)"]:::fs
end

