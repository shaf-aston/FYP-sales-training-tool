---
title: Session Lifecycle & Memory Recovery
---
%% ==========================================
%% PURPOSE: Documents the data lifecycle paths across new session initialisation, auto-product detection, in-memory recovery, disk-backup restore, and replay behaviors.
%% ==========================================
%%{init: {"theme": "base", "flowchart": {"nodeSpacing": 40, "rankSpacing": 40}}}%%

flowchart TD
    classDef junctionStyle width:0px,height:0px,stroke-width:0px,font-size:0px;
    classDef terminal fill:#37474F,stroke:#263238,stroke-width:2.5px,color:#fff
    classDef client   fill:#66BB6A,stroke:#1B5E20,stroke-width:2.5px,color:#fff
    classDef web      fill:#42A5F5,stroke:#0D47A1,stroke-width:2.5px,color:#fff
    classDef core     fill:#FFA726,stroke:#E65100,stroke-width:2.5px,color:#fff
    classDef feature  fill:#AB47BC,stroke:#4A148C,stroke-width:2.5px,color:#fff
    classDef obs      fill:#26C6DA,stroke:#006064,stroke-width:2.5px,color:#fff
    classDef fs       fill:#78909C,stroke:#37474F,stroke-width:2.5px,color:#fff
    classDef decision fill:#29B6F6,stroke:#0277BD,stroke-width:2px,color:#000

    PAGE_LOAD(["Browser page load / app start<br/>reads localStorage['session_id']"]:::terminal)

    HAS_ID{"session_id
in localStorage?"}:::decision

    PAGE_LOAD --> HAS_ID

    %% ═══════════════════════════════════════════════════════════════
    %% PATH A — New session, no product known
    %% ═══════════════════════════════════════════════════════════════
    HAS_ID -->|"No — first visit<br/>(no session_id stored)"| A_REQ

    subgraph PathA["Path A — New Session (unknown product)"]
        A_REQ["POST /api/init<br/>{product_type: null, user_message: ''}"]:::web
        A_CAP["SessionSecurityManager.can_create()<br/>→ True if below MAX_SESSIONS cap"]:::core
        A_ID["session_id = secrets.token_hex(16)<br/>(32-char cryptographic hex string)"]:::core
        A_BOT["SalesChatbot(provider='groq', product_type=None, session_id)<br/>get_product_settings(None) → default strategy = 'intent'<br/>SalesFlowEngine(flow_type='intent', stage=Stage.INTENT)"]:::core
        A_REC["SessionAnalytics.record_session_start(<br/>  session_id, product='unknown', strategy='intent', ab_variant)"]:::core
        A_GREET["prompts.generate_init_greeting('intent')<br/>→ opening line from STRATEGY_PROMPTS[consultative][init_greeting]<br/>  (INTENT mode uses CONSULTATIVE greeting template)"]:::core
        A_STORE["localStorage['session_id'] = session_id<br/>localStorage['history'] = []"]:::client
        A_REQ --> A_CAP --> A_ID --> A_BOT --> A_REC --> A_GREET --> A_STORE
    end

    %% ═══════════════════════════════════════════════════════════════
    %% PATH B — New session, product auto-detected from first message
    %% ═══════════════════════════════════════════════════════════════
    HAS_ID -->|"No — user typed first message<br/>(product hint in text)"| B_REQ

    subgraph PathB["Path B — Product Auto-Detection"]
        B_REQ["POST /api/init<br/>{product_type: null, user_message: 'I want to buy a car'}"]:::web
        B_QM["QuickMatcher.match_product(user_message)<br/>exact key → alias → fuzzy + context scoring<br/>Returns (product_key, confidence)"]:::core
        B_CONF{"confidence ≥ 0.7?"}:::decision
        B_ACCEPT["product_type = matched key  (e.g. 'cars' at 0.92)<br/>SalesChatbot(product_type='cars')<br/>product_config.yaml → strategy = 'consultative'<br/>SalesFlowEngine(flow_type='consultative')"]:::core
        B_REJECT["product_type = None<br/>Falls back to Path A behaviour<br/>strategy = 'intent' (discovery mode)"]:::core
        B_GREET["generate_init_greeting(strategy)<br/>→ strategy-specific opening message"]:::core
        B_REQ --> B_QM --> B_CONF
        B_CONF -->|"Yes — accepted"| B_ACCEPT --> B_GREET
        B_CONF -->|"No — below threshold"| B_REJECT --> B_GREET
    end

    %% ═══════════════════════════════════════════════════════════════
    %% PATH C — Existing session (page reload, server still has it)
    %% ═══════════════════════════════════════════════════════════════
    HAS_ID -->|"Yes — session_id in localStorage"| C_REQ

    C_REQ["POST /api/init  {session_id: 'abc123...'}"]:::web
    C_MEM{"session_manager.get(session_id)
found in memory?"}:::decision

    C_REQ --> C_MEM

    C_MEM -->|"Yes — server has it"| C_RESTORE["Return from memory:<br/>history · current_stage · strategy<br/>No new greeting (conversation already in progress)<br/>Response: {success:true, stage:'LOGICAL', strategy:'CONSULTATIVE', history:[...]}"]:::core

    %% ═══════════════════════════════════════════════════════════════
    %% PATH D — Session lost (server restart), try disk backup
    %% ═══════════════════════════════════════════════════════════════
    C_MEM -->|"No — not in memory<br/>(server restarted / deployed)"| D_DISK

    D_DISK{"sessions/{session_id}.json
disk backup exists?"}:::decision

    D_DISK -->|"Yes"| D_LOAD["SalesChatbot.load_session(session_id)<br/>→ restore SalesChatbot from JSON<br/>session_manager.set(session_id, restored_bot)<br/>Return: history · stage · strategy"]:::core

    %% ═══════════════════════════════════════════════════════════════
    %% PATH E — No disk backup, replay from localStorage history
    %% ═══════════════════════════════════════════════════════════════
    D_DISK -->|"No — no backup either"| E_ERR

    subgraph PathE["Path E — Replay from localStorage  (disaster recovery)"]
        E_ERR["App returns: {error: 'Session not found', code: 'SESSION_EXPIRED'}<br/>Browser reads localStorage['history'] = [{role,content} × N]"]:::feature
        E_REQ["Browser sends POST /api/restore<br/>{history: [{role,content}×N], product_type, provider}"]:::feature
        E_NEW_ID["new_session_id = secrets.token_hex(16)<br/>SalesChatbot(provider, product_type, new_session_id)"]:::feature
        E_REPLAY["bot.replay(history):<br/>  Iterates turn pairs in history<br/>  Calls FSM advancement logic on each pair<br/>  Reconstructs current_stage + strategy<br/>  NO LLM calls — purely deterministic reconstruction"]:::feature
        E_STORE["session_manager.set(new_session_id, bot)<br/>localStorage['session_id'] = new_session_id<br/>Return: {success:true, session_id:new_id, stage, strategy}"]:::feature
        E_ERR --> E_REQ --> E_NEW_ID --> E_REPLAY --> E_STORE
    end

    %% ═══════════════════════════════════════════════════════════════
    %% FORCE STRATEGY — Developer override
    %% ═══════════════════════════════════════════════════════════════
    FORCE_REQ["POST /api/init  {force_strategy: 'consultative', product_type: 'cars'}<br/>Sets _initial_flow_type = 'consultative'<br/>flow_engine.switch_strategy('consultative')<br/>Bypasses INTENT discovery — starts directly in CONSULTATIVE/INTENT"]:::fs

    %% ═══════════════════════════════════════════════════════════════
    %% SESSION RESET
    %% ═══════════════════════════════════════════════════════════════
    RESET_REQ["POST /api/reset  X-Session-ID header<br/>session_manager.delete(session_id)<br/>clear localStorage['session_id'] + localStorage['history']<br/>Browser redirects → fresh POST /api/init"]:::fs

    %% ═══════════════════════════════════════════════════════════════
    %% All successful paths converge to active session
    %% ═══════════════════════════════════════════════════════════════
    ACTIVE(["Active session — POST /api/chat available<br/>SalesChatbot in SessionSecurityManager<br/>  idle timeout resets on each request<br/>  background_cleanup() thread handles stale sessions"]:::terminal)

    A_STORE --> ACTIVE
    B_GREET --> ACTIVE
    C_RESTORE --> ACTIVE
    D_LOAD --> ACTIVE
    E_STORE --> ACTIVE
    FORCE_REQ --> ACTIVE
    RESET_REQ -->|"→ re-init"| PAGE_LOAD
