---
title: Chat Turn Sequence (3-Layer Control Highlighted)
---
%%{init: {"theme": "base", "sequence": {"actorMargin": 40, "messageMargin": 20}}}%%
%% Diagram Type: Sequence diagram (sequenceDiagram) — chat turn execution across layers (client → web → bot → provider)

sequenceDiagram
    box rgba(102,187,106,0.15) Client
        participant Br  as Browser
    end
    box rgba(66,165,245,0.15) Web Layer
        participant App as app.py
    end
    box rgba(255,167,38,0.15) Chatbot Core
        participant Bot as SalesChatbot
        participant FSM as SalesFlowEngine
        participant PE  as PromptEngine
    end
    box rgba(236,64,122,0.15) Provider
        participant Pv  as Provider
        participant API as LLM API
    end
    box rgba(38,198,218,0.15) Observability
        participant Obs as Analytics
    end

    %% Legend - Prompt Constraints / FSM Guards / Output Contracts

    Br->>App: POST /api/chat  {message}  X-Session-ID
    App->>App: validate_message() · rate_limit() · require_session()

    %% ── STEP 1: Prompt Assembly — LAYER 1 ──────────────────────────────────
    App->>Bot: bot.chat(user_message)
    Bot->>FSM: get_current_prompt(user_message)
    FSM->>PE: generate_stage_prompt(strategy, stage, context, history, msg)

    %% LAYER 1 - PROMPT CONSTRAINTS (Soft): instruction-level guidance the LLM should follow; this layer shapes intent and tone before generation.
    PE->>PE: Tier 1 — check_override_condition()

    alt Override triggered (direct_info / soft_positive / repetitive_validation)
        PE-->>FSM: override prompt (skips Tiers 2–4)
    else No override
        PE->>PE: Tier 2 — analyze_state() → acknowledgment context
        PE->>PE: Tier 3 — get_adaptive_guidance() → tactic injection
        PE->>PE: Tier 4 — base prompt + _SHARED_RULES
        PE-->>FSM: assembled system prompt
    end
    FSM-->>Bot: system_prompt

    %% ── STEP 2: Intent Recording ──────────────────────────────────────────
    Bot->>PE: analyze_state() [analytics only]
    PE-->>Bot: ConversationState
    Bot->>Obs: record_intent_classification()

    %% ── STEP 3: LLM Call ─────────────────────────────────────────────────
    Bot->>Pv: provider.chat(messages, temp=0.8, max_tokens=200)
    Pv->>API: HTTPS  llama-3.3-70b-versatile  (Groq primary)
    API-->>Pv: completion (~980 ms avg)
    Pv-->>Bot: LLMResponse

    alt Provider error / rate limit
        %% If the primary provider fails (rate-limit or error), the system automatically retries with backup providers (SambaNova -> OpenRouter) to avoid user interruption.
        Bot->>Pv: switch to SambaNova → OpenRouter
        Pv-->>Bot: LLMResponse (fallback)
    end

    %% ── STEP 4: Layer 3 — Output Contract ────────────────────────────────
    %% LAYER 3 - OUTPUT CONTRACTS (Hard): hard checks enforced by code detect failure modes in the bot's own output and set corrective flags for the next turn.
    Bot->>Bot: is_repetitive_validation(history)

    %% ── STEP 5: FSM Advancement — LAYER 2 ────────────────────────────────
    %% LAYER 2 - FSM GUARDS (Hard): hard readiness checks enforced by code to prevent premature advancement; ensure the bot only escalates when the user is ready.
    Bot->>Bot: _apply_advancement(user_message)

    alt flow_type == INTENT
        Bot->>Bot: _detect_and_switch_strategy()
        Bot->>FSM: switch_strategy(new_strategy)
        Bot->>Obs: record_strategy_switch()
    else CONSULTATIVE or TRANSACTIONAL
        Bot->>FSM: get_advance_target(user_message)
        alt Guards passed — advance
            FSM->>FSM: advance(target_stage)
            Bot->>Obs: record_stage_transition()
        else Blocked — stay in stage
            FSM-->>Bot: None
        end
    end

    %% ── STEP 6: Persist ──────────────────────────────────────────────────
    Bot->>FSM: add_turn(user_message, bot_reply)
    Bot->>Bot: save_session() → sessions/{id}.json
    Bot->>Obs: log_stage_latency()

    %% ── STEP 7: Objection (if applicable) ────────────────────────────────
    opt current_stage == OBJECTION
        Bot->>PE: classify_objection(user_message, history)
        PE-->>Bot: {type: see 05_nlu_pipeline.mmd for taxonomy}
        Bot->>Obs: record_objection_classified()
    end

    %% ── STEP 8: Response ─────────────────────────────────────────────────
    Bot-->>App: ChatResponse {content, latency_ms, provider, model}
    App->>Bot: generate_training(user_msg, bot_reply)
    %% Coaching/analysis step: produces internal feedback about the bot's sales technique; used for evaluation and improvement and not part of the live user-facing reply.
    Bot-->>App: {stage_goal, what_bot_did, next_trigger, watch_for}
    App-->>Br: JSON {success, message, stage, strategy, latency_ms, training}
