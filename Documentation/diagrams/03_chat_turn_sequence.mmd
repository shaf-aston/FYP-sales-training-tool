%% ==========================================
%% PURPOSE: Traces a single HTTP request through the system. Detail includes input validation, prompt assembly, LLM execution, Fallback chains, and response/analytics recording.
%% ==========================================
%%{init: {"theme": "base", "sequence": {"actorMargin": 30, "messageMargin": 25}}}%%

sequenceDiagram
    autonumber

    box rgba(102,187,106,0.15) Client
        participant Br  as Browser
    end
    box rgba(66,165,245,0.15) Web Layer
        participant App as app.py
    end
    box rgba(255,167,38,0.15) Chatbot Core
        participant Bot as SalesChatbot
        participant FSM as SalesFlowEngine
        participant PE  as PromptEngine
    end
    box rgba(171,71,188,0.15) Feature Modules
        participant WS as WebSearchService
    end
    box rgba(236,64,122,0.15) Provider Layer
        participant Pv  as Provider
        participant API as LLM API
    end
    box rgba(38,198,218,0.15) Observability
        participant Obs as Analytics + Metrics
    end

    Br->>App: POST /api/chat  {message: "..."}  X-Session-ID header
    note over App: @require_rate_limit('chat')
InputValidator.validate_message():
  strip whitespace · max_length=SecurityConfig.MAX_MESSAGE_LENGTH
  PromptInjectionValidator pattern scan
require_session(): session_manager.get(session_id)  OR  400 SESSION_EXPIRED

    App->>Bot: bot.chat(user_message)

    %% ── STEP 1: Prompt Assembly ──────────────────────────────────────────────
    note over Bot: recent_history = conversation_history[-10:]
chatbot.py lines 104–108: prompt assembled BEFORE intent recording

    Bot->>FSM: flow_engine.get_current_prompt(user_message)
    FSM->>FSM: strategy_for_prompts property:
  INTENT mode → returns CONSULTATIVE (uses consultative templates)
  else → returns actual flow_type (CONSULTATIVE or TRANSACTIONAL)

    FSM->>PE: generate_stage_prompt(strategy, stage, product_context, history, user_message)

    note over PE: PromptEngine = content.py + prompts.py + overrides.py + tactics.py + analysis.py

    PE->>PE: Tier 1 — check_override(user_message, stage, history, state)
  direct_info_request: 'price'/'cost'/'how much' (SIGNALS['direct_info_requests'])
  soft_positive at PITCH: 'yes'/'ok'/'sounds good'/'alright' AND stage==PITCH
  repetitive_validation: is_repetitive_validation(history, threshold from analysis_config.yaml)

    alt Override triggered (Tier 1 early-exit — skips Tiers 2–4)
        PE-->>FSM: override prompt returned immediately
    else No override
        PE->>PE: Tier 2 — analyze_state(history, user_message) → ConversationState
        PE->>PE: detect_acknowledgment_context(user_message, history, state)
  'full'  — user disclosed personal problem (vulnerability signal)
  'light' — guarded=True (defensive / evasive signals detected)
  'none'  — neutral info request  OR  state.decisive=True
        PE->>PE: Tier 3 — get_adaptive_guidance(state, stage, strategy)
  state.decisive → close guidance (DO NOT probe more)
  state.guarded  → back-off (single open question, do not push)
  is_literal_question(user_message) → answer directly first
  else → get_tactic('elicitation', subtype): random from tactics.yaml
        PE->>PE: Tier 4 — get_base_prompt(product_context, strategy, history)
  + STRATEGY_PROMPTS[strategy][stage]  (intent_low if state.intent=='low')
  + _SHARED_RULES + acknowledgment_guidance + adaptive_guidance
  + preference_context + keyword_context (lexical entrainment)
        PE-->>FSM: complete system prompt string
    end

    FSM-->>Bot: system_prompt

    %% ── STEP 1b: Optional Web Search Enrichment ──────────────────────────────
    opt current_stage == Stage.OBJECTION and should_trigger_web_search
        Bot->>WS: search(build_search_query(product, objection_type))
        WS-->>Bot: SearchResponse (DuckDuckGo results)
        Bot->>Bot: system_prompt += _format_search_context(results)
    end

    %% ── STEP 2: Intent Recording (AFTER prompt, BEFORE LLM) ─────────────────
    note over Bot: chatbot.py lines 111–121: separate analyze_state() call for analytics only
    Bot->>PE: analyze_state(conversation_history, user_message)
    PE-->>Bot: ConversationState  (only intent_level used here)
    Bot->>Obs: record_intent_classification(session_id, intent_level, user_turn_count)
    Obs-->>Bot: OK  [appends {event_type:'intent', ...} to analytics.jsonl]

    %% ── STEP 3: LLM Call ─────────────────────────────────────────────────────
    Bot->>Pv: provider.chat(llm_messages, temperature=0.8, max_tokens=200, stage)
    note over Pv: llm_messages = [{role:'system', content:system_prompt}]
               + conversation_history[-10:]
               + [{role:'user', content:user_message}]
@auto_log_performance decorator: measures wall-clock latency,
  fills response.latency_ms from timer if 0, logs error if set
    Pv->>API: HTTPS  llama-3.3-70b-versatile  (Groq primary)
    API-->>Pv: completion response  (~980 ms avg)
    Pv-->>Bot: LLMResponse {content, model, latency_ms, error=None}

    %% ── STEP 4: Fallback Chain ───────────────────────────────────────────────
    alt LLMResponse.error contains "rate_limit_exceeded" or "429" or any error
        note over Bot: fallbacks = ['sambanova', 'openrouter']  (current provider removed)
        Bot->>Pv: _try_switch_to_provider("sambanova")
        alt SambaNova available
            Pv->>API: HTTPS  Meta-Llama-3.1-70B  (SambaNova · openai SDK compat)
            API-->>Pv: completion
            Pv-->>Bot: LLMResponse (SambaNova)
        else SambaNova unavailable or error
            Bot->>Pv: _try_switch_to_provider("openrouter")
            alt OpenRouter available
                Pv->>API: HTTPS  llama-3.3-70b-instruct:free  (OpenRouter)
                API-->>Pv: completion
                Pv-->>Bot: LLMResponse (OpenRouter)
            else All fallbacks exhausted
                Bot->>Bot: _fallback("I'm having trouble connecting...")
  Appends static message to history WITHOUT incrementing stage_turn_count
                Bot-->>App: ChatResponse {content: static_error_message}
                App-->>Br: JSON {success:true, message: static_error_message}
            end
        end
    end

    %% ── STEP 5: Persist ──────────────────────────────────────────────────────
    Bot->>FSM: add_turn(user_message, bot_reply)
  history.append({role:'user', content:user_message})
  history.append({role:'assistant', content:bot_reply})
  stage_turn_count += 1
    Bot->>Bot: save_session()  →  sessions/{session_id}.json
    Bot->>Obs: log_stage_latency(session_id, stage, strategy, latency_ms,
  provider, model, user_message_length, bot_response_length)
    Obs-->>Bot: OK  [appends to metrics.jsonl · rotation at 5 000 lines → trim to 2 500]

    %% ── STEP 6: FSM Advancement ──────────────────────────────────────────────
    Bot->>Bot: _apply_advancement(user_message)

    alt flow_type == INTENT  (discovery mode)
        Bot->>Bot: _detect_and_switch_strategy(user_message)
  1) user_consultative_signals → switch_strategy(CONSULTATIVE)
  2) user_transactional_signals → switch_strategy(TRANSACTIONAL)
  3) stage_turn_count ≥ 3 → switch_strategy(CONSULTATIVE)  [default]
        alt Strategy switched
            Bot->>FSM: switch_strategy(new_strategy)
  flow_type updated · current_stage = Stage.INTENT · stage_turn_count = 0
            Bot->>Obs: record_strategy_switch(session_id, from, to, reason, turn_count)
        end
    else flow_type in {CONSULTATIVE, TRANSACTIONAL}
        Bot->>FSM: get_advance_target(user_message)
        note over FSM: 5 evaluation paths (in priority order):
  1 commitment signal at LOGICAL/EMOTIONAL → PITCH
  2 user_demands_directness() → PITCH
  3 direct_info_requests keywords → PITCH
  4 urgency_skip_to + impatience signal → skip stage
  5 ADVANCEMENT_RULES[advance_on](history, msg, stage_turn_count)
        alt Target stage returned
            FSM->>FSM: advance(target_stage)
  current_stage = target_stage · stage_turn_count = 0
            Bot->>Obs: record_stage_transition(session_id, from_stage, to_stage, strategy, turns_in_stage)
        else No advancement
            FSM-->>Bot: None  (stage unchanged)
        end
    end

    %% ── STEP 7: Objection Classification (OBJECTION stage only) ─────────────
    opt current_stage == Stage.OBJECTION
        Bot->>PE: classify_objection(user_message, history)
  Matches against 7 keyword sets in signals.yaml · first match wins
        PE-->>Bot: {type: smokescreen|money|fear|partner|logistical|think|unknown}
        Bot->>Obs: record_objection_classified(session_id, type, strategy, turn_count)
    end

    %% ── STEP 8: Response + Training (unconditional) ──────────────────────────
    Bot-->>App: ChatResponse {content, latency_ms, provider, model, input_len, output_len}

    note over App: generate_training() called UNCONDITIONALLY on every /api/chat  (app.py:376)
NOT conditional on ENABLE_DEBUG_PANEL
    App->>Bot: bot.generate_training(user_message, response.content)
    Bot-->>App: {stage_goal, what_bot_did, next_trigger, where_heading, watch_for: list[str]}

    App-->>Br: JSON {
  success: true,
  message: bot_reply,
  stage: current_stage.upper()  OR  "----" if INTENT mode,
  strategy: flow_type.upper(),
  latency_ms: round(latency_ms, 1),
  provider: _provider_name,
  model: _model_name,
  metrics: {input_length, output_length},
  training: {coaching, technique, score}
}
