%% Diagram standard header: see Documentation/diagrams/diagram-template.mmd
%%{init: {'flowchart': {'useHtmlLabels': true}}}%%
%% Caption: Prospect roleplay and quiz flow with scoring and coaching; wording kept simple for non-technical readers.
%% Purpose: Show exact code paths for prospect roleplay, post-session evaluation, and seller quiz/training tools.
%% Audience: Beginner to intermediate
%% Diagram type: flowchart TD

flowchart TD
    classDef user fill:#66BB6A,stroke:#1B5E20,stroke-width:2px,color:#fff
    classDef app fill:#42A5F5,stroke:#0D47A1,stroke-width:2px,color:#fff
    classDef logic fill:#FFA726,stroke:#E65100,stroke-width:2px,color:#fff
    classDef ai fill:#AB47BC,stroke:#4A148C,stroke-width:2px,color:#fff
    classDef done fill:#388E3C,stroke:#1B5E20,stroke-width:2px,color:#fff
    classDef decision fill:#F57F17,stroke:#E65100,stroke-width:2px,color:#fff
    classDef data fill:#78909C,stroke:#37474F,stroke-width:2px,color:#fff
    classDef info fill:#26C6DA,stroke:#006064,stroke-width:2px,color:#fff
    classDef topic fill:#26C6DA,stroke:#006064,stroke-width:2px,color:#fff
    classDef inHub fill:#26C6DA,stroke:#006064,stroke-width:2px,color:#fff

    LEGEND["DIAGRAM LEGEND: Green=user/output | Blue=endpoints/API | Orange=logic | Purple=LLM calls<br/>Gray=config/tests | Teal=topic hubs (logical grouping) | Diamond=decisions<br/>Solid arrow=direct call | Dotted=async/validates"]:::info

    subgraph PROSPECT
        direction TB
        PROSPECT_HUB(["Prospect Hub"]):::topic
        PROSPECT_START[Start]:::user
        PROSPECT_HUB --> PROSPECT_START
        PROSPECT_INIT[Init API]:::app
        PROSPECT_START --> PROSPECT_INIT
        PROSPECT_INIT --> PSESSION[ProspectSession]:::logic
        PSESSION --> PERSONA[Persona]:::logic
        PERSONA --> OPENING[Opening]:::ai
        OPENING --> LOOP[Session loop]:::logic

        LOOP --> USERMSG[User message]:::user
        USERMSG --> TURN[Process turn]:::logic
        TURN --> SCORE[Scoring]:::logic
        SCORE --> OUTCOME{End?}:::decision

        OUTCOME -- Active --> BUYERREPLY[Buyer reply]:::ai
        BUYERREPLY --> HINT{Show hints?}:::decision
        HINT -- Yes --> COACH[Coach hint]:::ai
        HINT -- No --> LOOP
        COACH --> LOOP

        OUTCOME -- Sold/walked --> EVALAPI[Evaluate]:::app
        EVALAPI --> EVALRUN[Evaluator]:::logic
        EVALRUN --> REPORT[Report]:::done
    end

    subgraph TRAINQUIZ
        direction TB
        CHAT[Chat endpoint]:::app --> TRAIN[Training]:::logic
        TRAIN --> TRAINING_PANEL_UI[Training panel]:::app

        TRAINING_PANEL_UI --> QUIZ_API[Quiz API]:::app
        QUIZ_API --> QUIZ_TYPE_SELECTION{Quiz type}:::decision

        QUIZ_TYPE_SELECTION -- Stage --> STAGE_QUIZ[Stage quiz]:::logic
        QUIZ_TYPE_SELECTION -- Next move --> NEXT_MOVE_QUIZ[Next-move quiz]:::ai
        QUIZ_TYPE_SELECTION -- Direction --> DIRECTION_QUIZ[Direction quiz]:::ai

        STAGE_QUIZ --> FINISH[Feedback returned to UI]:::done
        NEXT_MOVE_QUIZ --> FINISH
        DIRECTION_QUIZ --> FINISH
    end

    PROSPECT_CONFIG_FILE["src/config/prospect_config.yaml — personas + difficulty behavior"] --> CONFIG_TOPIC
    SIG["src/config/signals.yaml — message scoring signals"] --> CONFIG_TOPIC
    QUIZ_CONFIG_FILE["src/config/quiz_config.yaml — quiz rubrics and questions"] --> CONFIG_TOPIC
    CONFIG_TOPIC["Configs<br/>(topic)"]:::topic --> PROSPECT_HUB
    PROSPECT_HUB --> PERSONA
    PROSPECT_HUB --> SCORE
    CONFIG_TOPIC --> STAGE_QUIZ
    CONFIG_TOPIC --> NEXT_MOVE_QUIZ
    CONFIG_TOPIC --> DIRECTION_QUIZ

    EVALUATION_TOPIC[Evaluation]:::topic
    EVALAPI["/api/prospect/evaluate"]:::app --> EVALUATION_TOPIC
    EVALUATION_TOPIC --> EVALRUN[get_evaluation<br/>prospect_evaluator.evaluate_prospect_session]:::logic

    TEST_PROSPECT_FILE[tests/test_prospect.py]:::data -. validates .-> PROSPECT_IN
    TEST_QUIZ_FILE[tests/test_quiz.py]:::data -. validates .-> TRAINQUIZ
    TEST_TRAINER_FILE[tests/test_trainer_and_devpanel.py]:::data -. validates .-> TRAIN

