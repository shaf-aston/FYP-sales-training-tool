%%{init: {"theme": "base", "flowchart": {"nodeSpacing": 32, "rankSpacing": 32}}}%%
%% Title: 5 - NLU Pipeline - From user message to a structured conversation profile (intent, guardedness, objections, keywords)
%% Diagram Type: Flowchart (flowchart TD) — NLU pipeline: intent, guardedness, objection taxonomy, keyword engine

flowchart TD
  INPUT([Analyze message + history])

  %% Intent classification: HIGH / MEDIUM / LOW
  subgraph IntentFlow
    I_CHECK{Has the user explicitly stated a goal or need?}
    I_SIGNAL{Keyword matching vs intent templates}
    I_HIGH[HIGH intent - user clearly states a need; lock for session]
    I_MED[MEDIUM intent - partial signals; continue probing]
    I_LOW[LOW intent - exploratory or vague]
  end

  %% Guardedness: how open is the user to probing?
  subgraph GuardedFlow
    G_ENTRY[Detect guardedness - measure user openness to probing]
    G_RULES{Apply simple checks - agreement, dismissal, brevity, lack of detail}
    G_WEIGHT[Compute a configurable score - heuristic]
    G_TRUE[guarded: TRUE - reduce probing, prefer light acknowledgement]
    G_FALSE[guarded: FALSE - safe to ask direct clarifying questions]
  end

  %% Objection taxonomy: map surface reasons to root causes
  subgraph ObjFlow
    OBJ_IN[Classify objection - map to a known type for tailored reframe]
    OBJ_MATCH{Match vs objection sets}
    OBJ_S[smokescreen - stated reason may mask real concern]
    OBJ_M[money - cost barrier]
    OBJ_F[fear - anxiety or perceived risk]
    OBJ_P[partner - needs approval from someone else]
    OBJ_L[logistical - scheduling or delivery constraint]
    OBJ_T[think - asks for time to consider]
    OBJ_U[unknown - unclear or mixed signals]
  end

  %% Keyword engine: finds candidates and checks negation
  subgraph KWEngine
    KW_BUILD[Compile keyword/phrase patterns from configuration]
    KW_FIND[Find matches in user message and recent history]
    KW_NEG[Negation check - ensure matches are not negated]
    KW_RESULT[Return non-negated matches to classifier]
    KW_BUILD --> KW_FIND --> KW_NEG --> KW_RESULT
  end

  INPUT --> I_CHECK
  I_CHECK -->|Yes| I_HIGH
  I_CHECK -->|No| I_SIGNAL
  I_SIGNAL -->|High| I_HIGH
  I_SIGNAL -->|Low| I_LOW
  I_SIGNAL -->|None| I_MED

  IntentFlow --> G_ENTRY
  G_ENTRY --> G_RULES
  G_RULES -->|Above threshold| G_TRUE
  G_RULES -->|Below threshold| G_FALSE

  INPUT --> OBJ_IN
  OBJ_IN --> OBJ_MATCH
  OBJ_MATCH --> OBJ_S
  OBJ_MATCH --> OBJ_M
  OBJ_MATCH --> OBJ_F
  OBJ_MATCH --> OBJ_P
  OBJ_MATCH --> OBJ_L
  OBJ_MATCH --> OBJ_T
  OBJ_MATCH --> OBJ_U

  OBJ_MATCH -.->|negation-aware| KW_BUILD

  GuardedFlow --> OUT[ConversationState]
  ObjFlow --> OUT
  KWEngine --> OUT

  OUT([Final structured state: intent, guardedness, question_fatigue, decisive - this profile is handed to Layers 1-3 to decide tone, tactics, and whether to advance the stage])

  style INPUT fill:#FFF3E0,stroke:#E65100,color:#000
  style OUT fill:#FFF3E0,stroke:#E65100,color:#000
  style G_TRUE fill:#66BB6A,stroke:#1B5E20,color:#fff
  style G_FALSE fill:#66BB6A,stroke:#1B5E20,color:#fff
