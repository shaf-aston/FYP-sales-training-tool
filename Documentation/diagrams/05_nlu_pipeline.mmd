%%{init: {"theme": "base", "flowchart": {"nodeSpacing": 32, "rankSpacing": 32}}}%%
flowchart TD
  INPUT([Analyze message + history])

  subgraph IntentFlow[Intent Classification]
    I_CHECK{Has user stated goal?}
    I_SIGNAL{Match vs intent sets}
    I_HIGH[Intent: HIGH<br/>lock for session]
    I_LOW[Intent: LOW]
    I_MED[Intent: MEDIUM]
  end

  subgraph GuardedFlow[Guardedness Scoring]
    G_ENTRY[Detect guardedness]
    G_RULES{Apply checks:<br/>agreement, dismissal, elaboration}
    G_WEIGHT[Compute weighted score]
    G_TRUE[guarded: TRUE]
    G_FALSE[guarded: FALSE]
  end

  subgraph ObjFlow[Objection Classification]
    OBJ_IN[Classify objection]
    OBJ_MATCH{Match vs objection sets}
    OBJ_S[smokescreen]
    OBJ_M[money]
    OBJ_F[fear]
    OBJ_P[partner]
    OBJ_L[logistical]
    OBJ_T[think]
    OBJ_U[unknown]
  end

  subgraph KWEngine[Keyword Matching Engine]
    KW_BUILD[Compile regex pattern]
    KW_FIND[Find matches]
    KW_NEG[Negation check]
    KW_RESULT[Return non-negated match]
    KW_BUILD --> KW_FIND --> KW_NEG --> KW_RESULT
  end

  INPUT --> I_CHECK
  I_CHECK -->|Yes| I_HIGH
  I_CHECK -->|No| I_SIGNAL
  I_SIGNAL -->|High| I_HIGH
  I_SIGNAL -->|Low| I_LOW
  I_SIGNAL -->|None| I_MED

  IntentFlow --> G_ENTRY
  G_ENTRY --> G_RULES
  G_RULES -->|Above threshold| G_TRUE
  G_RULES -->|Below threshold| G_FALSE

  INPUT --> OBJ_IN
  OBJ_IN --> OBJ_MATCH
  OBJ_MATCH --> OBJ_S
  OBJ_MATCH --> OBJ_M
  OBJ_MATCH --> OBJ_F
  OBJ_MATCH --> OBJ_P
  OBJ_MATCH --> OBJ_L
  OBJ_MATCH --> OBJ_T
  OBJ_MATCH --> OBJ_U

  OBJ_MATCH -.->|negation-aware| KW_BUILD

  GuardedFlow --> OUT[ConversationState]
  ObjFlow --> OUT
  KWEngine --> OUT

  OUT([Final: intent, guarded, question_fatigue, decisive])

  style INPUT fill:#FFF3E0,stroke:#E65100,color:#000
  style OUT fill:#FFF3E0,stroke:#E65100,color:#000
  style G_TRUE fill:#66BB6A,stroke:#1B5E20,color:#fff
  style G_FALSE fill:#66BB6A,stroke:#1B5E20,color:#fff
