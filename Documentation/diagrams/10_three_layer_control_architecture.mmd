---
title: 3-Layer Control Architecture (Drift Prevention)
---
%%{init: {"theme": "base", "flowchart": {"nodeSpacing": 45, "rankSpacing": 45}}}%%

flowchart TD
    classDef prompt   fill:#9C27B0,stroke:#6A1B9A,color:#fff
    classDef fsm      fill:#D32F2F,stroke:#B71C1C,color:#fff
    classDef contract fill:#1976D2,stroke:#0D47A1,color:#fff
    classDef decision fill:#F57F17,stroke:#E65100,color:#fff
    classDef success  fill:#388E3C,stroke:#1B5E20,color:#fff
    classDef process  fill:#00897B,stroke:#004D40,color:#fff

    START(["User Message In"])

    START --> ANALYSIS["ANALYSIS PHASE
classify_intent · detect_guardedness
classify_objection · analyze_state"]:::process

    ANALYSIS --> LAYER1_ENTRY

    subgraph Layer1["🟪 LAYER 1 — PROMPT CONSTRAINTS (Soft Influence)"]
        LAYER1_ENTRY["check_override_condition()
overrides.py"]:::prompt

        LAYER1_CHECK{{"Condition?
direct_info_request
soft_positive @ pitch
repetitive_validation"}}:::decision

        OVERRIDE["Override Template
Early Exit — skip Tiers 2–4"]:::prompt
        STANDARD["Standard Pipeline
Tiers 2–4"]:::prompt

        TIERS["TIER 4 — SHARED_RULES applied to ALL strategies:
P1: No parroting more than 3 words
P1: No ending pitch with question mark
P2: Max 1–2 questions per response
P3: Match user tone
P4: Terse input: one observation + one question
P5: Persona checkpoint every N turns"]:::prompt

        PROMPT_OUT["System Prompt Generated"]:::prompt

        LAYER1_CHECK -->|Yes| OVERRIDE
        LAYER1_CHECK -->|No| STANDARD
        STANDARD --> TIERS
        OVERRIDE --> TIERS
        TIERS --> PROMPT_OUT
    end

    PROMPT_OUT --> LLM["LLM GENERATION
Groq — OpenRouter
Constrained by Layer 1 (soft influence)"]:::process

    LLM --> RESPONSE["LLM Response Generated
May still drift — Layer 2 and 3 catch it"]:::process

    RESPONSE --> LAYER2_ENTRY
    RESPONSE --> LAYER3_ENTRY

    subgraph Layer2["🔴 LAYER 2 — FSM GUARDS (Hard Blocking)"]
        LAYER2_ENTRY["_apply_advancement()
flow_engine.get_advance_target()"]:::fsm

        GUARD1["Guard 1: Min Turns Met?
Intent >= 1  Logical >= 2  Emotional >= 3"]:::fsm
        GUARD2["Guard 2: Signal Keyword Found?
text_contains_any_keyword()
in recent user messages (stage window filter)"]:::fsm
        GUARD3["Guard 3: Safety Valve?
turn_count >= max_turns (default 10)
Prevents infinite loops"]:::fsm

        RESULT{{"All Guards Passed?"}}:::decision

        ADVANCE["Advance to Next Stage"]:::success
        BLOCK["Stay in Current Stage
Blocked"]:::fsm

        LAYER2_ENTRY --> GUARD1 --> GUARD2 --> GUARD3 --> RESULT
        RESULT -->|Yes| ADVANCE
        RESULT -->|No| BLOCK
    end

    subgraph Layer3["🔵 LAYER 3 — OUTPUT CONTRACTS (Hard Validation)"]
        LAYER3_ENTRY["is_repetitive_validation()
Scan last 10 bot messages
Count excessive validation phrases"]:::contract

        VALIDATION_CHECK{{"Excessive Validation
Pattern Detected?"}}:::decision

        TRIGGER["Override Triggered
Force new topic on next turn"]:::contract
        NO_ISSUE["Response OK"]:::success

        LAYER3_ENTRY --> VALIDATION_CHECK
        VALIDATION_CHECK -->|Yes| TRIGGER
        VALIDATION_CHECK -->|No| NO_ISSUE
    end

    TRIGGER --> STORE
    NO_ISSUE --> STORE
    ADVANCE --> STORE
    BLOCK --> STORE

    STORE["Store in Conversation History
flow_engine.add_turn()"]:::process

    STORE --> END_NODE(["Chat Turn Complete
Next turn uses ACTUAL current_stage from FSM
Layer 1 alone: ~70% — All 3 layers: ~92%"]):::success
