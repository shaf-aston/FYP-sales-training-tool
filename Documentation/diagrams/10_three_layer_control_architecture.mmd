---
title: 3-Layer Control Architecture — Instruction-Based Guidance, FSM Advancement, Output Contracts
---
%%{init: {"theme": "base", "flowchart": {"nodeSpacing": 45, "rankSpacing": 45}}}%%

flowchart TD
    classDef prompt   fill:#9C27B0,stroke:#6A1B9A,color:#fff
    classDef fsm      fill:#D32F2F,stroke:#B71C1C,color:#fff
    classDef contract fill:#1976D2,stroke:#0D47A1,color:#fff
    classDef decision fill:#F57F17,stroke:#E65100,color:#fff
    classDef success  fill:#388E3C,stroke:#1B5E20,color:#fff
    classDef process  fill:#00897B,stroke:#004D40,color:#fff

    START(["User Message In"])

    START --> ANALYSIS["ANALYSIS PHASE
classify_intent · detect_guardedness
classify_objection · analyze_state"]:::process

    ANALYSIS --> LAYER1_ENTRY

    subgraph Layer1["🟪 LAYER 1 — INSTRUCTION-BASED GUIDANCE (Prompt-level instruction and template constraints)"]
        LAYER1_ENTRY["check_prompt_override_condition()\n(overrides: prompt-level override for next-turn prompt)"]:::prompt

        LAYER1_CHECK{{"Override Condition?\n• direct_info_request\n• soft_positive @ PITCH\n• repetitive_validation\n• explicit force_override_flag (session metadata)"}}:::decision

        OVERRIDE["Override Template\nEarly Exit — return override system prompt (skip Tier 2–4)"]:::prompt
        STANDARD["Standard Pipeline\nApply Tiers 2–4 analysis"]:::prompt

        TIERS["TIER 2–4 — Adaptive Analysis & Prompt Assembly:\nTier 2: analyze_state() → acknowledgment context\nTier 3: get_adaptive_guidance() → tactic injection\nTier 4: assemble base prompt + _SHARED_RULES (persona, output schema, question limits)\nSHARED RULES:\nP1: Do not repeat user text verbatim (anti-parroting)\nP2: No pitch ending with a question mark\nP3: Max 1–2 questions per response\nP4: Match user tone\nP5: Persona checkpoint every N turns"]:::prompt

        PROMPT_OUT["System Prompt Generated\nIncludes instruction templates, persona constraints, and output-format constraints (e.g., response schema)"]:::prompt

        LAYER1_CHECK -->|Yes| OVERRIDE
        LAYER1_CHECK -->|No| STANDARD
        STANDARD --> TIERS
        TIERS --> PROMPT_OUT
        OVERRIDE --> PROMPT_OUT
    end

    PROMPT_OUT --> LLM["LLM GENERATION\nGroq / OpenRouter\nProduces content + metadata (role, tokens, heuristics)"]:::process

    LLM --> RESPONSE["LLM Response\n(content, tokens, metadata)"]:::process

    %% Clarify concurrency: Layer 2 and Layer 3 evaluate the response in parallel.
    RESPONSE --> PARALLEL_NOTE["Parallel evaluation:\nLayer 2 (FSM Advancement Guards) and Layer 3 (Output Validation) run independently this turn.\nLayer 2 decides immediate stage advancement for this turn.\nLayer 3 sets validation flags (e.g., force_override_next_turn) stored for the next-turn prompt assembly."]:::decision

    PARALLEL_NOTE --> LAYER2_ENTRY
    PARALLEL_NOTE --> LAYER3_ENTRY

    subgraph Layer2["🔴 LAYER 2 — FSM ADVANCEMENT GUARDS (Rule-based gating)"]
        LAYER2_ENTRY["_apply_advancement()\nflow_engine.get_advance_target()"]:::fsm

        GUARD1["Guard 1: Minimum turns met?\nIntent: ≥1  · Logical: ≥2  · Emotional: ≥3\n(heuristic defaults; configurable in analysis_config.yaml)"]:::fsm
        GUARD2["Guard 2: Required signal present?\ntext_contains_any_keyword() in recent user messages (stage window filter)"]:::fsm
        SAFETY["Safety Valve / Fallback (configurable)\nTrigger if turn_count ≥ max_turns (see analysis_config.yaml)"]:::fsm

        RESULT{{"All Guards Passed?"}}:::decision

        ADVANCE["Advance to Next Stage"]:::success
        BLOCK["Stay in Current Stage (Blocked)"]:::fsm

        LAYER2_ENTRY --> GUARD1 --> GUARD2 --> SAFETY --> RESULT
        RESULT -->|Yes| ADVANCE
        RESULT -->|No| BLOCK
    end

    subgraph Layer3["🔵 LAYER 3 — OUTPUT CONTRACTS (Automated Response Validation)"]
        LAYER3_ENTRY["is_repetitive_validation()\nScan last N bot messages for excessive validation phrases"]:::contract

        VALIDATION_CHECK{{"Validation: excessive pattern detected?"}}:::decision

        TRIGGER["Override Triggered — set force_override_next_turn flag in session metadata"]:::contract
        NO_ISSUE["No validation issue detected"]:::success

        LAYER3_ENTRY --> VALIDATION_CHECK
        VALIDATION_CHECK -->|Yes| TRIGGER
        VALIDATION_CHECK -->|No| NO_ISSUE
    end

    TRIGGER --> STORE_OVERRIDE["Store override flag (force_override_next_turn) in session metadata"]:::process
    NO_ISSUE --> STORE_HISTORY["Store conversation turn in history (flow_engine.add_turn())"]:::process
    ADVANCE --> STORE_HISTORY
    BLOCK --> STORE_HISTORY
    STORE_OVERRIDE --> STORE_HISTORY

    STORE_HISTORY --> END_NODE(["Chat Turn Complete\nNext turn starts with ACTUAL current_stage (from FSM) and any stored override flags"]):::success

    %% Provenance note for heuristics and thresholds
    PROVENANCE["Provenance: Guard thresholds and other heuristics are configuration defaults (analysis_config.yaml). They are tunable and not presented here as empirical performance claims."]:::process
    PROVENANCE --- SAFETY
