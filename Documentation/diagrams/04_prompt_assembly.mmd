---
title: 4-Tier Prompt Assembly Pipeline
---
%% ==========================================
%% PURPOSE: Visualizes how prompts are programmatically constructed by combining exact overrides, tactical acknowledgements, adaptive advice, and core NEPQ templates.
%% ==========================================
%%{init: {"theme": "base", "flowchart": {"nodeSpacing": 40, "rankSpacing": 40}}}%%

flowchart TD
    classDef junctionStyle stroke-width:0px,fill:transparent,font-size:1px;
    classDef override fill:#D32F2F,stroke:#B71C1C,stroke-width:2.5px,color:#fff
    classDef ack fill:#7B1FA2,stroke:#4A148C,stroke-width:2.5px,color:#fff
    classDef tactics fill:#388E3C,stroke:#1B5E20,stroke-width:2.5px,color:#fff
    classDef stage fill:#1976D2,stroke:#0D47A1,stroke-width:2.5px,color:#fff
    classDef final fill:#F57F17,stroke:#E65100,stroke-width:2.5px,color:#fff

    START(["flow_engine.get_current_prompt(user_message)<br/>strategy_for_prompts:<br/>  INTENT mode → CONSULTATIVE templates<br/>  else → actual flow_type (CONSULTATIVE or TRANSACTIONAL)"]):::stage

    ENTRY["content.generate_stage_prompt(<br/>  strategy: str,   ← from strategy_for_prompts<br/>  stage: Stage,<br/>  product_context: str,<br/>  history: list,<br/>  user_message: str<br/>)"]:::stage

    START --> ENTRY

    %% ── TIER 1: Override Check ───────────────────────────────────────────────
    ENTRY --> T1{{"TIER 1 — Override Check  (overrides.py)"}}:::override

    T1 -->|"direct_info_request"| OV1["overrides.get_override_template('direct_info')"]:::override
    T1 -->|"soft_positive at PITCH"| OV2["overrides.early_exit_prompt(stage)"]:::override
    T1 -->|"repetitive_validation loop"| OV3["overrides.get_override_template('excessive_validation')"]:::override

    T1 -->|"None of the above"| T2_ENTRY

    OVJ1[ ]:::junctionStyle
    OV1 --- OVJ1
    OV2 --- OVJ1
    OV3 --- OVJ1
    OVJ1 --> FINAL_PROMPT

    %% ── TIER 2: Acknowledgment ───────────────────────────────────────────────
    subgraph Tier2["TIER 2 — Acknowledgment Guidance"]
        T2_ENTRY["analysis.analyze_state(history, user_message)"]:::ack
        T2_ACK["analysis.detect_acknowledgment_context(user_message)"]:::ack
        T2_FULL["'full' — user disclosed personal problem"]:::ack
        T2_LIGHT["'light' — guarded=True"]:::ack
        T2_NONE["'none' — neutral / decisive=True"]:::ack

        T2_ENTRY --> T2_ACK
        T2_ACK -->|"vulnerability"| T2_FULL
        T2_ACK -->|"guarded > 0.4"| T2_LIGHT
        T2_ACK -->|"neutral"| T2_NONE
    end

    T2J[ ]:::junctionStyle
    T2_FULL --- T2J
    T2_LIGHT --- T2J
    T2_NONE --- T2J
    T2J --> T3_ENTRY

    %% ── TIER 3: Adaptive Tactics ─────────────────────────────────────────────
    subgraph Tier3["TIER 3 — Adaptive Tactical Guidance"]
        T3_ENTRY["tactics.get_adaptive_guidance(state, stage, strategy)"]:::tactics
        T3_DEC["state.decisive == True  (Focus on close)"]:::tactics
        T3_GUARD["state.guarded == True  (Back off)"]:::tactics
        T3_QUES["is_literal_question()  (Answer first)"]:::tactics
        T3_ELICIT["Default — loader.get_tactic('elicitation')"]:::tactics

        T3_ENTRY -->|"decisive"| T3_DEC
        T3_ENTRY -->|"guarded"| T3_GUARD
        T3_ENTRY -->|"literal question"| T3_QUES
        T3_ENTRY -->|"none of above"| T3_ELICIT
    end

    Tier2 --- Tier3

    T3J[ ]:::junctionStyle
    T3_DEC --- T3J
    T3_GUARD --- T3J
    T3_QUES --- T3J
    T3_ELICIT --- T3J
    T3J --> T4_ENTRY

    %% ── TIER 4: Stage Assembly (Strategy-Specific) ──────────────────────────
    subgraph Tier4["TIER 4 — Base Prompt + Shared Rules"]
        T4_ENTRY["loader.get_base_prompt(<br/>  product_context, strategy, history<br/>)"]:::stage
        
        T4_ROUTE{"strategy == ?"}:::stage
        
        T4_CONSULT["CONSULTATIVE[stage]<br/>+ _SHARED_RULES<br/>+ Tier 2–3 context"]:::stage
        T4_TRANS["TRANSACTIONAL[stage]<br/>+ _SHARED_RULES<br/>+ Tier 2–3 context"]:::stage
        
        T4_SHARED["_SHARED_RULES (shared across strategies):<br/>  P1: NO parroting > 3 words<br/>  P1: NO pitch ending with '?'<br/>  P2: Max 1–2 questions/response<br/>  P3: Match user tone<br/>  P4: Terse input guidance<br/>  P5: Persona checkpoint"]:::stage
        
        T4_PREFS["lexical_entrainment +<br/>preference_context +<br/>intent_level variations"]:::stage

        T4_ENTRY --> T4_ROUTE
        T4_ROUTE -->|CONSULTATIVE| T4_CONSULT
        T4_ROUTE -->|TRANSACTIONAL| T4_TRANS
        T4_CONSULT --> T4_SHARED
        T4_TRANS --> T4_SHARED
        T4_SHARED --> T4_PREFS
    end

    Tier3 --- Tier4

    T4_PREFS --> FINAL_PROMPT["System Prompt Complete<br/>(override OR assembled)<br/>→ Ready for LLM call"]:::final
