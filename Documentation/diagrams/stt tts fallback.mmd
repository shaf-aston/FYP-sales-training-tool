graph TD
    %% Base Styling
    classDef input fill:#e2e2e2,stroke:#999,stroke-width:1px,color:#000;
    classDef decision fill:#f8f9fa,stroke:#ccc,stroke-width:1px,color:#000,shape:diamond;
    classDef process fill:#f8f9fa,stroke:#ccc,stroke-width:1px,color:#000;
    classDef error fill:#fce4ec,stroke:#ef9a9a,stroke-width:1px,color:#d32f2f;
    classDef success fill:#e8f5e9,stroke:#a5d6a7,stroke-width:1px,color:#2e7d32;
    classDef fallback fill:#fff3e0,stroke:#ffb74d,stroke-width:1px,color:#e65100;
    classDef frontend fill:#e3f2fd,stroke:#90caf9,stroke-width:1px,color:#1565c0;

    subgraph STT_Flow ["Browser STT Pipeline (voice.js)"]
        A_STT(Audio Input Blob) -->|POST /api/voice/chat| B_STT{Backend Deepgram<br/>Available?}
        B_STT -- Yes --> C_STT{Rate Limited?}
        B_STT -- No --> H_STT[Catch Frontend Error]
        
        C_STT -- No --> D_STT[Call Deepgram Nova-2]
        C_STT -- Yes --> E_STT[Throw Error 429]
        D_STT --> F_STT{Success?}
        F_STT -- Yes --> G_STT[Return Backend Transcription]
        F_STT -- Exception --> H_STT
        E_STT --> H_STT
        
        H_STT -->|Fallback Triggered| I_STT[Call puter.ai.speech2txt]
        I_STT --> J_STT{Puter Success?}
        J_STT -- Yes --> K_STT[Send Transcript via JSON to Backend]
        J_STT -- No --> L_STT[Fatal Error: User Notified]
        
        G_STT --> M_STT[Continue to LLM Chat]
        K_STT --> M_STT
    end

    subgraph TTS_Flow ["Browser TTS Pipeline (app.js)"]
        A_TTS(LLM Response Text) -->|POST /api/voice/synthesize| B_TTS{Backend Edge TTS<br/>Available?}
        B_TTS -- Yes --> D_TTS[Call Edge TTS]
        B_TTS -- No --> H_TTS[Catch Frontend Error]
        
        D_TTS --> F_TTS{Success?}
        F_TTS -- Yes --> G_TTS[Return Audio Blob]
        F_TTS -- Exception --> H_TTS
        
        H_TTS -->|Fallback Triggered| I_TTS[Call puter.ai.txt2speech]
        I_TTS --> J_TTS{Puter Success?}
        
        J_TTS -- Yes --> K_TTS[Return HTMLAudioElement]
        J_TTS -- No --> L_TTS[Fatal Error: Fallback failed]
        
        G_TTS --> M_TTS[Play Audio in Browser]
        K_TTS --> M_TTS
    end

    class A_STT,A_TTS input;
    class B_STT,C_STT,F_STT,J_STT,B_TTS,F_TTS,J_TTS decision;
    class D_STT,D_TTS process;
    class E_STT,H_STT,L_STT,H_TTS,L_TTS error;
    class G_STT,M_STT,G_TTS,M_TTS success;
    class I_STT,K_STT,I_TTS,K_TTS fallback;
    class STT_Flow,TTS_Flow frontend;