---
title: Features Class Diagram
---
%% ==========================================
%% PURPOSE: Outlines the specific implementation models for the supplementary Training hooks, Quizzes, Product matching (Loader pattern), and the evaluation utilities.
%% ==========================================
%%{init: {"theme": "base"}}%%

classDiagram

    %% ── Prospect Mode ────────────────────────────────────────────────────────
    class ProspectState {
        <<dataclass>>
        +float readiness
        +int objections_raised
        +int turn_count
        +list needs_disclosed
        +bool has_committed
        +bool has_walked
        +dict persona
        +str difficulty
        +str product_type
        +list conversation_history
    }
    note for ProspectState "readiness ∈ [0.0, 1.0]."

    class ProspectResponse {
        <<dataclass>>
        +str content
        +float readiness
        +str readiness_label
        +str outcome
        +Optional~dict~ hint
        +int turn_count
        +float latency_ms
    }
    note for ProspectResponse "readiness_label from range_label(): 5 labels from 'Very skeptical' to 'Nearly ready to buy'."

    class ProspectSession {
        +str session_id
        +str product_type
        +str difficulty
        +ProspectState state
        +BaseLLMProvider provider
        +dict prospect_config
        +get_opening_message() ProspectResponse
        +process_turn(str, bool) ProspectResponse
        +get_evaluation() dict
        +to_dict() dict
        +from_dict(dict)$ ProspectSession
        -_update_readiness(str, str) None
        -_score_sales_message(str, str) int
        -_check_end_conditions() str
        -_generate_coaching_hint(str) dict
        -_build_system_prompt() str
    }
    note for ProspectSession "_score_sales_message() is DETERMINISTIC — no LLM per turn:."

    class ProspectEvaluator {
        <<module>>
        +evaluate_session(dict, BaseLLMProvider)$ dict
        -_score_rubric_item(str, list, provider)$ dict
    }
    note for ProspectEvaluator "Post-session LLM rubric: NEPQ stage coverage."

    %% ── Quiz ─────────────────────────────────────────────────────────────────
    class QuizModule {
        <<module>>
        +get_quiz_question(str)$ dict
        +evaluate_stage_quiz(str, SalesChatbot)$ dict
        +evaluate_next_move_quiz(str, SalesChatbot, str)$ dict
        +evaluate_direction_quiz(str, SalesChatbot)$ dict
    }
    note for QuizModule "stage quiz: deterministic match to current FSM stage."

    %% ── Trainer ──────────────────────────────────────────────────────────────
    class TrainerModule {
        <<module>>
        +generate_training(...)$ dict
        +answer_training_question(str, dict, BaseLLMProvider)$ dict
    }
    note for TrainerModule "Called UNCONDITIONALLY on every /api/chat response."

    %% ── Knowledge ────────────────────────────────────────────────────────────
    class KnowledgeModule {
        <<module>>
        +load_custom_knowledge()$ dict
        +save_custom_knowledge(dict)$ bool
        +clear_custom_knowledge()$ bool
        +get_custom_knowledge_text()$ str
        +ALLOWED_FIELDS list$
        +MAX_FIELD_LENGTH int$
    }
    note for KnowledgeModule "get_custom_knowledge_text() injected into product_context at SalesChatbot.__init__."

    %% ── NLU Module (analysis.py — all module-level functions) ────────────────
    class AnalysisModule {
        <<module>>
        +analyze_state(list, str, dict)$ ConversationState
        +classify_intent_level(list, str, signal_keywords)$ str
        +detect_guardedness(str, list)$ float
        +text_contains_any_keyword(str, keywords)$ bool
        +is_literal_question(str)$ bool
        +user_demands_directness(list, str)$ bool
        +is_repetitive_validation(list, int)$ bool
        +detect_acknowledgment_context(str, list, state)$ str
        +extract_preferences(list)$ str
        +extract_user_keywords(list, int)$ list
        +classify_objection(str, list)$ dict
        +commitment_or_walkaway(list, str)$ bool
    }
    note for AnalysisModule "Pure functions only — no state, no decisions, no LLM calls."

    %% ── Prompt System (all module-level functions) ───────────────────────────
    class ContentModule {
        <<module>>
        +generate_stage_prompt(...)$ str
        -_get_stage_specific_prompt(...)$ str
        -_get_preference_and_keyword_context(list, str)$ str
    }
    note for ContentModule "Orchestrates 4-tier pipeline: Tier1 override → Tier2 ack → Tier3 tactics → Tier4 assembly."

    class PromptsModule {
        <<module>>
        +STRATEGY_PROMPTS dict$
        +_SHARED_RULES str$
        +get_prompt(str, str)$ str
        +get_base_prompt(str, str, list)$ str
        +generate_init_greeting(str)$ dict
        +get_acknowledgment_guidance(str)$ str
    }
    note for PromptsModule "STRATEGY_PROMPTS keys: consultative→{intent,intent_low,logical,emotional,pitch,objection}."

    class OverridesModule {
        <<module>>
        +check_override(...)$ Optional~str~
        +is_direct_info_request(str)$ bool
        +is_soft_positive(str, stage)$ bool
    }
    note for OverridesModule "Tier 1 early-exit — bypasses Tiers 2–4 entirely if triggered."

    class TacticsModule {
        <<module>>
        +get_adaptive_guidance(ConversationState, stage, strategy)$ str
        -_build_decisive_guidance(stage, strategy)$ str
        -_build_guarded_guidance()$ str
        -_build_question_guidance()$ str
    }

    %% ── FSM Rules (module-level functions in flow.py) ────────────────────────
    class AdvancementRulesModule {
        <<module>>
        +FLOWS dict$
        +_COMMON_TRANSITIONS dict$
        +ADVANCEMENT_RULES dict$
        +user_has_clear_intent(list, str, int)$ bool
        +user_shows_doubt(list, str, int)$ bool
        +user_expressed_stakes(list, str, int)$ bool
        +commitment_or_objection(list, str, int)$ bool
        -_check_advancement_condition(...)$ bool
    }
    note for AdvancementRulesModule "_COMMON_TRANSITIONS reused by both strategies:."

    %% ── Relationships ────────────────────────────────────────────────────────
    ProspectSession *-- ProspectState              : state (composition)
    ProspectSession ..> ProspectResponse           : returns
    ProspectSession --> ProspectEvaluator          : delegates post-session eval
    ProspectSession --> QuickMatcher               : loads prospect_config

    ContentModule --> PromptsModule                : stage templates
    ContentModule --> OverridesModule              : Tier 1 override check
    ContentModule --> TacticsModule                : Tier 3 tactical guidance
    ContentModule --> AnalysisModule               : analyze_state() + detect_ack()

    AnalysisModule ..> ConversationState           : produces

    AdvancementRulesModule --> AnalysisModule      : commitment_or_walkaway (avoids circular import)
    AdvancementRulesModule --> ContentModule       : SIGNALS dict imported by content

    SalesChatbot --> WebSearchService              : optional search


    class WebSearchService {
        -_cache_ttl: int
        -_cache: dict
        +search(str, int) SearchResponse
        -_fetch(str, int)
    }

    %% ── Colour Scheme ────────────────────────────────────────────────────────
    classDef featureStyle fill:#AB47BC,stroke:#4A148C,stroke-width:2.5px,color:#fff
    classDef coreStyle    fill:#FFA726,stroke:#E65100,stroke-width:2.5px,color:#fff
    classDef dtoStyle     fill:#26C6DA,stroke:#006064,stroke-width:2.5px,color:#fff

    class ProspectState      featureStyle
    class ProspectResponse   featureStyle
    class ProspectSession    featureStyle
    class ProspectEvaluator  featureStyle
    class QuizModule         featureStyle
    class TrainerModule      featureStyle
    class KnowledgeModule    featureStyle
    class WebSearchService   featureStyle
    class AnalysisModule     coreStyle
    class ContentModule      coreStyle
    class PromptsModule      coreStyle
    class OverridesModule    coreStyle
    class TacticsModule      coreStyle
    class AdvancementRulesModule coreStyle
