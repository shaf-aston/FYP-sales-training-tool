%% ==========================================
%% PURPOSE: Outlines the specific implementation models for the supplementary Training hooks, Quizzes, Product matching (Loader pattern), and the evaluation utilities.
%% ==========================================
%%{init: {"theme": "base"}}%%

%% Diagram Type: UML Class Diagram (classDiagram) — Feature modules, utilities, and analysis helpers

classDiagram

    %% NOTE: this diagram shows code organization (modules, classes and their relationships), not the live conversation flow. It is primarily for developers and verification; non-technical readers can skip it.

    %% ── Prospect Mode ────────────────────────────────────────────────────────
    class ProspectState {
        <<dataclass>>
        +float readiness
        +int objections_raised
        +int turn_count
        +list needs_disclosed
        +bool has_committed
        +bool has_walked
        +dict persona
        +str difficulty
        +str product_type
        +list conversation_history
    }
    note for ProspectState "readiness ∈ [0.0, 1.0]."

    class ProspectResponse {
        <<dataclass>>
        +str content
        +float readiness
        +str readiness_label
        +str outcome
        +Optional~dict~ hint
        +int turn_count
        +float latency_ms
    }
    note for ProspectResponse "readiness_label from range_label(): 5 labels from 'Very skeptical' to 'Nearly ready to buy'."

    class ProspectSession {
        +str session_id
        +str product_type
        +str difficulty
        +ProspectState state
        +BaseLLMProvider provider
        +dict prospect_config
        +get_opening_message() ProspectResponse
        +process_turn(str, bool) ProspectResponse
        +get_evaluation() dict
        +to_dict() dict
        +from_dict(dict) {classmethod} ProspectSession
        -_update_readiness(str, str) None
        -_score_sales_message(str, str) int
        -_check_end_conditions() str
        -_generate_coaching_hint(str) dict
        -_build_system_prompt() str
    }
    note for ProspectSession "_score_sales_message() is DETERMINISTIC — no LLM per turn:."

    class ProspectEvaluator {
        <<utility>>
        +evaluate_prospect_session(provider, list, ProspectState, str) {static} dict
        -_grade_from_score(int) {static} str
    }
    note for ProspectEvaluator "Post-session performance scoring."

    %% ── Quiz ─────────────────────────────────────────────────────────────────
    class QuizModule {
        <<utility>>
        +get_stage_rubric(str, str) {static} dict
        +get_quiz_question(str) {static} dict
        +evaluate_stage_quiz(str, SalesChatbot) {static} dict
    }
    note for QuizModule "Assessment: stage identification, next-move, direction."

    %% ── Trainer ──────────────────────────────────────────────────────────────
    class TrainerModule {
        <<utility>>
        +generate_training(provider, SalesFlowEngine, str, str) {static} dict
        +answer_training_question(str, dict, provider) {static} dict
    }
    note for TrainerModule "Coaching feedback on every /api/chat response."

    %% ── Knowledge ────────────────────────────────────────────────────────────
    class KnowledgeModule {
        <<utility>>
        +load_custom_knowledge() {static} dict
        +save_custom_knowledge(dict) {static} bool
        +clear_custom_knowledge() {static} bool
        +get_custom_knowledge_text() {static} str
    }
    note for KnowledgeModule "Custom product knowledge injection at session init."

    %% ── Analysis Module (analysis.py — module-level functions only) ─────────
    class AnalysisModule {
        <<utility>>
        +analyze_state(list, str, dict) {static} ConversationState
        +classify_intent_level(list, str, keywords) {static} str
        +detect_guardedness(str, list) {static} float
        +detect_acknowledgment_context(str, list, state) {static} str
        +extract_preferences(list) {static} str
        +classify_objection(str, list) {static} dict
        +commitment_or_walkaway(list, str) {static} bool
        +should_trigger_web_search(list) {static} bool
    }
    note for AnalysisModule "Pure analysis functions. Called by chatbot.py before prompt assembly."

    %% ── Content Module (content.py — orchestrates prompt generation) ────────
    class ContentModule {
        <<utility>>
        +generate_stage_prompt(...) {static} str
        -_get_stage_specific_prompt(...) {static} str
        -_get_preference_and_keyword_context(list, str) {static} str
    }
    note for ContentModule "Assembles final prompt: overrides → tactics → base."

    %% ── Prompts Module (prompts.py — strategy-specific templates) ──────────
    class PromptsModule {
        <<utility>>
        +STRATEGY_PROMPTS dict {static}
        +_SHARED_RULES str {static}
    }
    note for PromptsModule "Template storage: {strategy}{stage} → prompt skeleton."

    %% ── Overrides Module (overrides.py — early-exit conditions) ────────────
    class OverridesModule {
        <<utility>>
        +check_override_condition(...) {static} Optional~str~
    }
    note for OverridesModule "Tier 1: Direct info request or soft positive at pitch."

    %% ── Tactics Module (tactics.py — user state adaptation) ────────────────
    class TacticsModule {
        <<utility>>
        +build_tactic_guidance(ConversationState, stage, strategy) {static} str
    }
    note for TacticsModule "Adapts guidance based on user state: decisive, guarded, low-intent."

    %% ── Flow Rules (flow.py — FSM state + advancement logic) ──────────────
    class SalesFlowEngineModule {
        <<utility>>
        +user_has_clear_intent(list, str, int) {static} bool
        +user_shows_doubt(list, str, int) {static} bool
        +user_expressed_stakes(list, str, int) {static} bool
        +commitment_or_objection(list, str, int) {static} bool
    }
    note for SalesFlowEngineModule "Advancement predicate utilities. Prefer using core `SalesFlowEngine` (Documentation/diagrams/06_class_diagram_core.mmd); consider merging predicates as static methods on `SalesFlowEngine`."

    %% ── Web Search Integration ───────────────────────────────────────────────
    class WebSearchService {
        +search(str, int) {static} SearchResponse
        -_fetch(str, int) {static} SearchResponse
        -_normalize_query(str) {static} str
        -_cache_get(str) {static} Optional~SearchResponse~
        -_cache_set(str, SearchResponse) {static} None
    }
    note for WebSearchService "Caches DuckDuckGo results. See SearchResult and SearchResponse dataclasses below."

    %% ── Web Search DTOs (added to satisfy relationships) ───────────────────
    class SearchResult {
        <<dataclass>>
        +str title
        +str url
        +str snippet
    }

    class SearchResponse {
        <<dataclass>>
        +list~SearchResult~ results
        +str query
        +bool cached
        +float latency_ms
    }

    %% ── Reference Stubs / Relationships ─────────────────────────────────────
    %% Stubs reference core classes so cross-diagram arrows have definitions.
    class SalesChatbot {
        <<ref>>
    }

    class QuickMatcher {
        <<ref>>
    }

    class ConversationState {
        <<ref>>
    }

    %% ── Relationships ────────────────────────────────────────────────────────
    ProspectSession "1" *-- "1" ProspectState              : state (composition)
    ProspectSession "1" ..> "1" ProspectResponse           : returns
    ProspectSession "1" --> "1" ProspectEvaluator          : evaluates performance
    ProspectSession "1" --> "1" QuickMatcher               : loads prospect_config

    ContentModule --> PromptsModule                : fetches templates
    ContentModule --> OverridesModule              : checks early-exit
    ContentModule --> TacticsModule                : gets guidance
    ContentModule --> AnalysisModule               : calls for state

    AnalysisModule ..> ConversationState           : produces

    SalesFlowEngineModule --> AnalysisModule       : calls for signals
    SalesFlowEngineModule --> ContentModule        : needs signals dict

    SalesChatbot "1" --> "0..1" WebSearchService              : optional web search

    %% ── Colour Scheme ────────────────────────────────────────────────────────
    classDef featureStyle fill:#AB47BC,stroke:#4A148C,stroke-width:2.5px,color:#fff
    classDef coreStyle    fill:#FFA726,stroke:#E65100,stroke-width:2.5px,color:#fff
    classDef dtoStyle     fill:#26C6DA,stroke:#006064,stroke-width:2.5px,color:#fff

    class ProspectState      featureStyle
    class ProspectResponse   featureStyle
    class ProspectSession    featureStyle
    class ProspectEvaluator  featureStyle
    class QuizModule         featureStyle
    class TrainerModule      featureStyle
    class KnowledgeModule    featureStyle
    class WebSearchService   featureStyle
    class AnalysisModule     coreStyle
    class ContentModule      coreStyle
    class PromptsModule      coreStyle
    class OverridesModule    coreStyle
    class TacticsModule      coreStyle
    class SalesFlowEngineModule coreStyle

    %% ── Legend / Notation ───────────────────────────────────────────────────
    classDef legendStyle fill:#f7f7f7,stroke:#333,stroke-width:1px,color:#000
    class Legend {
        <<note>>
        +Color legend: featureStyle = Features; coreStyle = Core; dtoStyle = DTOs
        +Notation: {static} = static method; {classmethod} = classmethod
        +Stereotypes: <<utility>> = stateless utility; <<ref>> = cross-diagram reference
    }
    class Legend legendStyle
